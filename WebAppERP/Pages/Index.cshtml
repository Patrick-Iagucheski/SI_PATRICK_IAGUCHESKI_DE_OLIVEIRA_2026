@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<!-- KPI Cards -->
<div class="row g-3 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card kpi-blue">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-label">Agendamentos Hoje</div>
                    <div class="kpi-value mt-1">@Model.TotalAgendamentosHoje</div>
                </div>
                <div class="kpi-icon" style="background: #dbeafe; color: #3b82f6;">
                    <i class="bi bi-calendar-check"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card kpi-green">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-label">Faturamento do Mes</div>
                    <div class="kpi-value mt-1">R$ @Model.FaturamentoMes.ToString("N2")</div>
                </div>
                <div class="kpi-icon" style="background: #dcfce7; color: #10b981;">
                    <i class="bi bi-currency-dollar"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card kpi-orange">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-label">Clientes Ativos</div>
                    <div class="kpi-value mt-1">@Model.TotalClientesAtivos</div>
                </div>
                <div class="kpi-icon" style="background: #fef3c7; color: #f59e0b;">
                    <i class="bi bi-people"></i>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card kpi-card kpi-purple">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <div class="kpi-label">Servicos Realizados</div>
                    <div class="kpi-value mt-1">@Model.TotalServicosMes</div>
                </div>
                <div class="kpi-icon" style="background: #ede9fe; color: #8b5cf6;">
                    <i class="bi bi-check2-circle"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Faturamento Semanal</h6>
                <div class="chart-wrapper">
                    <canvas id="chartFaturamento"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h6 class="fw-bold mb-3">Servicos Mais Solicitados</h6>
                <div class="chart-wrapper">
                    <canvas id="chartServicos"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Tables Row -->
<div class="row g-3">
    <div class="col-lg-7">
        <div class="table-container">
            <div class="table-header">
                <h5><i class="bi bi-calendar-event me-2"></i>Proximos Agendamentos</h5>
                <a href="/Cadastro/Agendamentos" class="btn btn-sm btn-outline-primary">Ver Todos</a>
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Horario</th>
                            <th>Cliente</th>
                            <th>Servico</th>
                            <th>Profissional</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ProximosAgendamentos.Any())
                        {
                            @foreach (var a in Model.ProximosAgendamentos)
                            {
                                var badgeClass = a.TpStatus switch
                                {
                                    "AGENDADO" => "badge-agendado",
                                    "CONFIRMADO" => "badge-confirmado",
                                    "EM_ATENDIMENTO" => "badge-em-atendimento",
                                    "CONCLUIDO" => "badge-concluido",
                                    _ => "badge-agendado"
                                };
                                <tr>
                                    <td><strong>@a.HrInicio.ToString("HH:mm")</strong></td>
                                    <td>@a.Cliente?.NmCliente</td>
                                    <td>@a.Servico?.DsServico</td>
                                    <td>@a.Funcionario?.NmFuncionario</td>
                                    <td><span class="badge-status @badgeClass">@a.TpStatus.Replace("_", " ")</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center text-muted py-4">Nenhum agendamento encontrado</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="table-container">
            <div class="table-header">
                <h5><i class="bi bi-clock-history me-2"></i>Ultimas Vendas</h5>
            </div>
            <div class="table-responsive">
                <table class="table">
                    <thead>
                        <tr>
                            <th>Venda</th>
                            <th>Cliente</th>
                            <th>Valor</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.UltimasVendas.Any())
                        {
                            @foreach (var v in Model.UltimasVendas)
                            {
                                var badgeClass = v.TpStatus switch
                                {
                                    "FINALIZADA" => "badge-concluido",
                                    "CANCELADA" => "badge-cancelado",
                                    _ => "badge-agendado"
                                };
                                <tr>
                                    <td>#@v.IdVenda</td>
                                    <td>@(v.Cliente?.NmCliente ?? "-")</td>
                                    <td><strong>R$ @v.VlTotal.ToString("N2")</strong></td>
                                    <td><span class="badge-status @badgeClass">@v.TpStatus</span></td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4" class="text-center text-muted py-4">Nenhuma venda encontrada</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
    <script>
        // Dados reais vindos do banco de dados
        const faturamentoLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FaturamentoSemanaLabels));
        const faturamentoValores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FaturamentoSemanaValores));
        const servicosLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ServicosLabels));
        const servicosValores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ServicosValores));

        // Faturamento Semanal - Bar Chart
        new Chart(document.getElementById('chartFaturamento'), {
            type: 'bar',
            data: {
                labels: faturamentoLabels,
                datasets: [{
                    label: 'Faturamento (R$)',
                    data: faturamentoValores,
                    backgroundColor: 'rgba(59, 130, 246, 0.7)',
                    borderColor: '#3b82f6',
                    borderWidth: 1,
                    borderRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: { callback: v => 'R$ ' + v }
                    }
                }
            }
        });

        // Servicos Mais Solicitados - Doughnut Chart
        const servicosCanvas = document.getElementById('chartServicos');
        if (servicosValores.length > 0) {
            new Chart(servicosCanvas, {
                type: 'doughnut',
                data: {
                    labels: servicosLabels,
                    datasets: [{
                        data: servicosValores,
                        backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#8b5cf6', '#ef4444'],
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { padding: 12, font: { size: 11 } }
                        }
                    }
                }
            });
        } else {
            servicosCanvas.parentElement.innerHTML =
                '<div class="d-flex align-items-center justify-content-center h-100 text-muted">Nenhum servico registrado no periodo</div>';
        }
    </script>
}
