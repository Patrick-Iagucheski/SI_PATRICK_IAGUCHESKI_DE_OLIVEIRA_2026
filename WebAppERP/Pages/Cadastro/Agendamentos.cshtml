@page
@model WebAppERP.Pages.Cadastro.AgendamentosModel
@{
    ViewData["Title"] = "Agendamentos";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">Agendamentos</h1>
        <p class="page-subtitle">Gerencie a agenda da barbearia</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalAgendamento" onclick="limparForm()">
        <i class="bi bi-plus-lg me-1"></i> Novo Agendamento
    </button>
</div>

<!-- KPI Resumo -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card kpi-card kpi-blue">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="kpi-label">Agendados</div>
                    <div class="kpi-value mt-1" style="font-size:1.4rem;">@Model.QtdAgendados</div>
                </div>
                <i class="bi bi-calendar-event text-primary fs-3"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card kpi-purple">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="kpi-label">Confirmados</div>
                    <div class="kpi-value mt-1" style="font-size:1.4rem;">@Model.QtdConfirmados</div>
                </div>
                <i class="bi bi-calendar-check fs-3" style="color:#8b5cf6;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card kpi-orange">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="kpi-label">Em Atendimento</div>
                    <div class="kpi-value mt-1" style="font-size:1.4rem;">@Model.QtdEmAtendimento</div>
                </div>
                <i class="bi bi-hourglass-split fs-3" style="color:#f59e0b;"></i>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card kpi-card kpi-green">
            <div class="card-body d-flex align-items-center justify-content-between py-3">
                <div>
                    <div class="kpi-label">Concluidos</div>
                    <div class="kpi-value mt-1" style="font-size:1.4rem;">@Model.QtdConcluidos</div>
                </div>
                <i class="bi bi-check-circle text-success fs-3"></i>
            </div>
        </div>
    </div>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-center">
            <div class="col-md-3">
                <div class="search-box">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="form-control" placeholder="Buscar cliente..." id="searchInput" />
                </div>
            </div>
            <div class="col-md-2">
                <input type="date" class="form-control" name="DataFiltro" value="@Model.DataFiltro" onchange="this.form.submit()" />
            </div>
        </form>
    </div>
</div>

<!-- Tabela -->
<div class="table-container">
    <div class="table-header">
        <h5><i class="bi bi-calendar-check-fill me-2"></i>Agenda do Dia - @(DateOnly.TryParse(Model.DataFiltro, out var dt) ? dt.ToString("dd/MM/yyyy") : "")</h5>
    </div>
    <div class="table-responsive">
        <table class="table" id="tblAgendamentos">
            <thead>
                <tr>
                    <th>Horario</th>
                    <th>Cliente</th>
                    <th>Servico</th>
                    <th>Profissional</th>
                    <th>Duracao</th>
                    <th>Valor</th>
                    <th>Status</th>
                    <th class="text-center">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Agendamentos.Any())
                {
                    @foreach (var a in Model.Agendamentos)
                    {
                        var badgeClass = a.TpStatus switch
                        {
                            "AGENDADO" => "badge-agendado",
                            "CONFIRMADO" => "badge-confirmado",
                            "EM_ATENDIMENTO" => "badge-em-atendimento",
                            "CONCLUIDO" => "badge-concluido",
                            "CANCELADO" => "badge-cancelado",
                            _ => "badge-agendado"
                        };
                        var isCancelado = a.TpStatus == "CANCELADO";
                        <tr class="@(isCancelado ? "table-light text-decoration-line-through" : "")">
                            <td><strong>@a.HrInicio.ToString("HH:mm")@(a.HrFim.HasValue ? $" - {a.HrFim.Value:HH:mm}" : "")</strong></td>
                            <td>@a.Cliente?.NmCliente</td>
                            <td>@a.Servico?.DsServico</td>
                            <td>@a.Funcionario?.NmFuncionario</td>
                            <td>@(a.Servico?.NrDuracaoMin.HasValue == true ? $"{a.Servico.NrDuracaoMin} min" : "-")</td>
                            <td>R$ @(a.Servico?.VlServico.ToString("N2") ?? "0,00")</td>
                            <td><span class="badge-status @badgeClass">@a.TpStatus.Replace("_", " ")</span></td>
                            <td class="text-center">
                                @if (a.TpStatus == "AGENDADO")
                                {
                                    <form method="post" asp-page-handler="Status" class="d-inline">
                                        <input type="hidden" name="id" value="@a.IdAgendamento" />
                                        <input type="hidden" name="status" value="CONFIRMADO" />
                                        <input type="hidden" name="data" value="@Model.DataFiltro" />
                                        <button type="submit" class="btn btn-icon btn-outline-info" title="Confirmar"><i class="bi bi-check2"></i></button>
                                    </form>
                                }
                                @if (a.TpStatus == "CONFIRMADO")
                                {
                                    <form method="post" asp-page-handler="Status" class="d-inline">
                                        <input type="hidden" name="id" value="@a.IdAgendamento" />
                                        <input type="hidden" name="status" value="EM_ATENDIMENTO" />
                                        <input type="hidden" name="data" value="@Model.DataFiltro" />
                                        <button type="submit" class="btn btn-icon btn-outline-warning" title="Iniciar"><i class="bi bi-play-fill"></i></button>
                                    </form>
                                }
                                @if (a.TpStatus == "EM_ATENDIMENTO")
                                {
                                    <form method="post" asp-page-handler="Status" class="d-inline">
                                        <input type="hidden" name="id" value="@a.IdAgendamento" />
                                        <input type="hidden" name="status" value="CONCLUIDO" />
                                        <input type="hidden" name="data" value="@Model.DataFiltro" />
                                        <button type="submit" class="btn btn-icon btn-outline-success" title="Concluir"><i class="bi bi-check-lg"></i></button>
                                    </form>
                                }
                                @if (a.TpStatus != "CONCLUIDO" && a.TpStatus != "CANCELADO")
                                {
                                    <form method="post" asp-page-handler="Status" class="d-inline" onsubmit="return confirm('Cancelar este agendamento?')">
                                        <input type="hidden" name="id" value="@a.IdAgendamento" />
                                        <input type="hidden" name="status" value="CANCELADO" />
                                        <input type="hidden" name="data" value="@Model.DataFiltro" />
                                        <button type="submit" class="btn btn-icon btn-outline-danger" title="Cancelar"><i class="bi bi-x-lg"></i></button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Nenhum agendamento para esta data</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Novo Agendamento -->
<div class="modal fade" id="modalAgendamento" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title"><i class="bi bi-calendar-plus me-2"></i>Novo Agendamento</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="AgendamentoForm.IdAgendamento" id="aId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Cliente *</label>
                            <select class="form-select" asp-for="AgendamentoForm.IdCliente" required>
                                <option value="">Selecione o cliente</option>
                                @foreach (var c in Model.Clientes)
                                {
                                    <option value="@c.IdCliente">@c.NmCliente</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Profissional *</label>
                            <select class="form-select" asp-for="AgendamentoForm.IdFuncionario" required>
                                <option value="">Selecione o profissional</option>
                                @foreach (var f in Model.Funcionarios)
                                {
                                    <option value="@f.IdFuncionario">@f.NmFuncionario</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Servico *</label>
                            <select class="form-select" asp-for="AgendamentoForm.IdServico" required>
                                <option value="">Selecione o servico</option>
                                @foreach (var s in Model.Servicos)
                                {
                                    <option value="@s.IdServico">@s.DsServico - R$ @s.VlServico.ToString("N2") (@(s.NrDuracaoMin ?? 0) min)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Data *</label>
                            <input type="date" class="form-control" asp-for="AgendamentoForm.DtAgendamento" value="@Model.DataFiltro" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Horario *</label>
                            <input type="time" class="form-control" asp-for="AgendamentoForm.HrInicio" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Horario Fim</label>
                            <input type="time" class="form-control" asp-for="AgendamentoForm.HrFim" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select class="form-select" asp-for="AgendamentoForm.TpStatus">
                                <option value="AGENDADO">Agendado</option>
                                <option value="CONFIRMADO">Confirmado</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Observacoes</label>
                            <textarea class="form-control" rows="2" asp-for="AgendamentoForm.DsObservacao"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Agendar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput')?.addEventListener('input', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#tblAgendamentos tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });

        function limparForm() {
            document.getElementById('aId').value = '0';
        }
    </script>
}
