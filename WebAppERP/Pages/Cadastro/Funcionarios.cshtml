@page
@model WebAppERP.Pages.Cadastro.FuncionariosModel
@{
    ViewData["Title"] = "Funcionarios";

    string FormatarCPF(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        return d.Length == 11
            ? $"{d[..3]}.{d.Substring(3, 3)}.{d.Substring(6, 3)}-{d.Substring(9, 2)}"
            : (string.IsNullOrEmpty(v) ? "-" : v);
    }

    string FormatarTelefone(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        if (d.Length == 11) return $"({d[..2]}) {d.Substring(2, 5)}-{d.Substring(7, 4)}";
        if (d.Length == 10) return $"({d[..2]}) {d.Substring(2, 4)}-{d.Substring(6, 4)}";
        return string.IsNullOrEmpty(v) ? "-" : v;
    }
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">Funcionarios</h1>
        <p class="page-subtitle">Gerencie os profissionais da barbearia</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalFuncionario" onclick="limparForm()">
        <i class="bi bi-plus-lg me-1"></i> Novo Funcionario
    </button>
</div>

<!-- Filtros de busca (todos opcionais e combinaveis) -->
<div class="card mb-3">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">ID</label>
                <input type="number" class="form-control" id="buscaId" min="1" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Funcionario</label>
                <input type="text" class="form-control" id="buscaNome" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Apelido</label>
                <input type="text" class="form-control" id="buscaApelido" autocomplete="off" />
            </div>
            <div class="col-md-4">
                <label class="form-label small mb-1">CPF</label>
                <input type="text" class="form-control" id="buscaCpf" maxlength="14" placeholder="000.000.000-00" autocomplete="off" />
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="buscaInativos" onchange="buscarFuncionarios()" />
                <label class="form-check-label" for="buscaInativos">Exibir Funcionarios Inativos</label>
            </div>
            <button type="button" class="btn btn-primary" onclick="buscarFuncionarios()">
                <i class="bi bi-search me-1"></i>Buscar
            </button>
        </div>
    </div>
</div>

<!-- Tabela -->
<div class="table-container">
    <div class="table-header">
        <h5><i class="bi bi-person-badge-fill me-2"></i>Lista de Funcionarios</h5>
        <span class="text-muted small" id="contadorRegistros">@Model.Funcionarios.Count registros encontrados</span>
    </div>
    <div class="table-responsive">
        <table class="table" id="tblFuncionarios">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Funcionario</th>
                    <th>CPF</th>
                    <th>Cargo</th>
                    <th>Telefone</th>
                    <th>Admissao</th>
                    <th>Comissao</th>
                    <th>Status</th>
                    <th class="text-center">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Funcionarios.Any())
                {
                    @foreach (var f in Model.Funcionarios)
                    {
                        <tr>
                            <td>@f.IdFuncionario</td>
                            <td><strong>@f.NmFuncionario</strong></td>
                            <td>@FormatarCPF(f.NrCpf)</td>
                            <td>@(f.Cargo?.NmCargo ?? f.DsCargo)</td>
                            <td>@FormatarTelefone(f.NrTelefone)</td>
                            <td>@f.DtAdmissao.ToString("dd/MM/yyyy")</td>
                            <td>@(f.VlComissao.HasValue ? $"{f.VlComissao}%" : "-")</td>
                            <td>
                                @if (f.FlAtivo)
                                {
                                    <span class="badge-status badge-ativo">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inativo">Inativo</span>
                                }
                            </td>
                            <td class="text-center">
                                <button class="btn btn-icon btn-outline-primary" title="Editar"
                                        data-bs-toggle="modal" data-bs-target="#modalFuncionario"
                                        onclick="editarFunc(@f.IdFuncionario,'@f.NmFuncionario.Replace("'", "\\'")','@f.NrCpf','@f.NrTelefone','@f.DsEmail','@f.DsEndereco?.Replace("'", "\\'")','@f.DsBairro?.Replace("'", "\\'")','@(f.IdCidade?.ToString() ?? "")','@f.NrCEP','@(f.DtNascimento?.ToString("yyyy-MM-dd") ?? "")','@f.DtAdmissao.ToString("yyyy-MM-dd")','@(f.DtDemissao?.ToString("yyyy-MM-dd") ?? "")','@(f.IdCargo?.ToString() ?? "")','@(f.VlSalario?.ToString("F2") ?? "")','@(f.VlComissao?.ToString("F2") ?? "")','@f.DsObservacao?.Replace("'", "\\'")','@f.FlAtivo','@f.NmApelido?.Replace("'", "\\'")','@f.NrRG','@f.NrNumero','@f.DsComplemento?.Replace("'", "\\'")','@f.DsSexo')">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Deseja realmente excluir este funcionario?')">
                                    <input type="hidden" name="id" value="@f.IdFuncionario" />
                                    <button type="submit" class="btn btn-icon btn-outline-danger" title="Excluir">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">Nenhum funcionario cadastrado</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal -->
<div class="modal fade" id="modalFuncionario" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle"><i class="bi bi-person-badge me-2"></i>Novo Funcionario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="FuncionarioForm.IdFuncionario" id="fId" />
                    <div class="row g-3">
                        <!-- Codigo (somente leitura) | Funcionario | Apelido -->
                        <div class="col-md-2">
                            <label class="form-label">Codigo</label>
                            <input type="text" class="form-control bg-light" id="fCodigoDisplay" placeholder="(novo)" readonly />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Funcionario *</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.NmFuncionario" id="fNome" maxlength="200" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Apelido</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.NmApelido" id="fApelido" maxlength="100" />
                        </div>

                        <!-- CPF | RG | Sexo | Data de Nascimento -->
                        <div class="col-md-3">
                            <label class="form-label">CPF *</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.NrCpf" id="fCpf" maxlength="14" placeholder="000.000.000-00" required />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">RG</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.NrRG" id="fRg" maxlength="9" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Sexo</label>
                            <select class="form-select" asp-for="FuncionarioForm.DsSexo" id="fSexo">
                                <option value="">Selecione</option>
                                <option value="Masculino">Masculino</option>
                                <option value="Feminino">Feminino</option>
                                <option value="Outro">Outro</option>
                                <option value="Prefiro nao informar">Prefiro nao informar</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Data de Nascimento</label>
                            <input type="date" class="form-control" asp-for="FuncionarioForm.DtNascimento" id="fNasc" />
                        </div>

                        <!-- Endereco | Numero -->
                        <div class="col-md-8">
                            <label class="form-label">Endereco</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.DsEndereco" id="fEnd" maxlength="200" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Numero</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.NrNumero" id="fNumero" maxlength="10" />
                        </div>

                        <!-- Complemento | Bairro -->
                        <div class="col-md-6">
                            <label class="form-label">Complemento</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.DsComplemento" id="fComplemento" maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bairro</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.DsBairro" id="fBairro" maxlength="100" />
                        </div>

                        <!-- Cidade (cadastro rapido) | CEP -->
                        <div class="col-md-8">
                            <label class="form-label">Cidade</label>
                            <div class="input-group">
                                <select class="form-select" asp-for="FuncionarioForm.IdCidade" id="fCidade">
                                    <option value="">Selecione</option>
                                    @foreach (var cidade in Model.Cidades)
                                    {
                                        <option value="@cidade.IdCidade">@cidade.NmCidade / @cidade.Estado?.SgUF</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#modalCidadeRapido" title="Cadastrar nova cidade">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">CEP</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.NrCEP" id="fCep" maxlength="9" placeholder="00000-000" />
                        </div>

                        <!-- Telefone | E-mail -->
                        <div class="col-md-6">
                            <label class="form-label">Telefone</label>
                            <input type="text" class="form-control" asp-for="FuncionarioForm.NrTelefone" id="fTel" maxlength="15" placeholder="(00) 00000-0000" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" asp-for="FuncionarioForm.DsEmail" id="fEmail" maxlength="150" />
                        </div>

                        <!-- Cargo (cadastro rapido) | Admissao | Demissao -->
                        <div class="col-md-4">
                            <label class="form-label">Cargo *</label>
                            <div class="input-group">
                                <select class="form-select" asp-for="FuncionarioForm.IdCargo" id="fCargo" required>
                                    <option value="">Selecione</option>
                                    @foreach (var cargo in Model.Cargos)
                                    {
                                        <option value="@cargo.IdCargo">@cargo.NmCargo</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#modalCargoRapido" title="Cadastrar novo cargo">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Data de Admissao *</label>
                            <input type="date" class="form-control" asp-for="FuncionarioForm.DtAdmissao" id="fAdm" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Data de Demissao</label>
                            <input type="date" class="form-control" asp-for="FuncionarioForm.DtDemissao" id="fDem" />
                        </div>

                        <!-- Salario | Comissao | Status -->
                        <div class="col-md-4">
                            <label class="form-label">Salario (R$)</label>
                            <input type="number" class="form-control" asp-for="FuncionarioForm.VlSalario" id="fSal" step="0.01" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Comissao (%)</label>
                            <input type="number" class="form-control" asp-for="FuncionarioForm.VlComissao" id="fCom" step="0.01" min="0" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Status</label>
                            <select class="form-select" asp-for="FuncionarioForm.FlAtivo" id="fAtivo">
                                <option value="true">Ativo</option>
                                <option value="false">Inativo</option>
                            </select>
                        </div>

                        <!-- Observacoes -->
                        <div class="col-12">
                            <label class="form-label">Observacoes</label>
                            <textarea class="form-control" rows="2" asp-for="FuncionarioForm.DsObservacao" id="fObs" maxlength="500"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Cadastro Rapido de Cargo (AJAX) -->
<div class="modal fade" id="modalCargoRapido" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-briefcase me-2"></i>Cadastrar Cargo</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="crMsg"></div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Nome do Cargo *</label>
                        <input type="text" class="form-control" id="crNome" maxlength="100" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Descricao</label>
                        <textarea class="form-control" rows="2" id="crDesc" maxlength="300"></textarea>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Comissao Padrao (%)</label>
                        <input type="number" class="form-control" id="crComissao" step="0.01" min="0" max="100" />
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSalvarCargoRapido" onclick="salvarCargoRapido()">
                    <i class="bi bi-check-lg me-1"></i>Salvar Cargo
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Cadastro Rapido de Cidade (AJAX) -->
<div class="modal fade" id="modalCidadeRapido" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-building me-2"></i>Cadastrar Cidade</h5>
