<!-- Token antiforgery para as chamadas AJAX (form isolado, fora do form de funcionario) -->
<form id="formCargoRapidoToken" class="d-none">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script>
        document.getElementById('searchInput')?.addEventListener('input', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#tblFuncionarios tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });

        // ===== Mascaras (somente exibicao; no banco salva so numeros) =====
        function mascaraCPF(v) {
            return v.replace(/\D/g, '').slice(0, 11)
                .replace(/^(\d{3})(\d)/, '$1.$2')
                .replace(/^(\d{3})\.(\d{3})(\d)/, '$1.$2.$3')
                .replace(/\.(\d{3})(\d)/, '.$1-$2');
        }
        function mascaraCEP(v) {
            return v.replace(/\D/g, '').slice(0, 8).replace(/^(\d{5})(\d)/, '$1-$2');
        }
        function mascaraTelefone(v) {
            v = v.replace(/\D/g, '').slice(0, 11);
            if (v.length > 10)
                return v.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
            return v.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3').trim();
        }
        function aplicarMascara(id, fn) {
            const el = document.getElementById(id);
            el?.addEventListener('input', () => { el.value = fn(el.value); });
        }
        aplicarMascara('fCpf', mascaraCPF);
        aplicarMascara('fCep', mascaraCEP);
        aplicarMascara('fTel', mascaraTelefone);

        function limparForm() {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-person-badge me-2"></i>Novo Funcionario';
            ['fId','fNome','fApelido','fCpf','fRg','fSexo','fTel','fEmail','fEnd','fBairro','fNumero','fComplemento','fCidade','fCep','fNasc','fAdm','fDem','fCargo','fSal','fCom','fObs','fCodigoDisplay'].forEach(id => {
                document.getElementById(id).value = '';
            });
            document.getElementById('fId').value = '0';
            document.getElementById('fAtivo').value = 'true';
        }

        function editarFunc(id,nome,cpf,tel,email,end,bairro,cidade,cep,nasc,adm,dem,idCargo,sal,com,obs,ativo,apelido,rg,numero,complemento,sexo) {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Editar Funcionario';
            document.getElementById('fId').value = id;
            document.getElementById('fCodigoDisplay').value = id;
            document.getElementById('fNome').value = nome;
            document.getElementById('fApelido').value = apelido;
            document.getElementById('fCpf').value = mascaraCPF(cpf || '');
            document.getElementById('fRg').value = rg;
            document.getElementById('fSexo').value = sexo || '';
            document.getElementById('fTel').value = mascaraTelefone(tel || '');
            document.getElementById('fEmail').value = email;
            document.getElementById('fEnd').value = end;
            document.getElementById('fBairro').value = bairro;
            document.getElementById('fNumero').value = numero;
            document.getElementById('fComplemento').value = complemento;
            document.getElementById('fCidade').value = cidade;
            document.getElementById('fCep').value = mascaraCEP(cep || '');
            document.getElementById('fNasc').value = nasc;
            document.getElementById('fAdm').value = adm;
            document.getElementById('fDem').value = dem;
            document.getElementById('fCargo').value = idCargo;
            document.getElementById('fSal').value = sal;
            document.getElementById('fCom').value = com;
            document.getElementById('fObs').value = obs;
            document.getElementById('fAtivo').value = ativo === 'True' ? 'true' : 'false';
        }

        // ===== Cadastro rapido de Cargo (AJAX) - sem sair da tela de Funcionarios =====
        async function salvarCargoRapido() {
            const nome = document.getElementById('crNome').value.trim();
            const desc = document.getElementById('crDesc').value.trim();
            const comissao = document.getElementById('crComissao').value;
            const msg = document.getElementById('crMsg');
            const btn = document.getElementById('btnSalvarCargoRapido');
            msg.innerHTML = '';

            if (!nome) {
                msg.innerHTML = '<div class="alert alert-danger py-1 px-2 small mb-2">Informe o nome do cargo.</div>';
                return;
            }

            const token = document.querySelector('#formCargoRapidoToken input[name="__RequestVerificationToken"]').value;

            btn.disabled = true;
            try {
                const resp = await fetch('?handler=CargoRapido', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': token
                    },
                    body: JSON.stringify({
                        nmCargo: nome,
                        dsCargo: desc || null,
                        vlComissaoPadrao: comissao ? parseFloat(comissao) : null
                    })
                });

                const data = await resp.json();

                if (!data.sucesso) {
                    msg.innerHTML = '<div class="alert alert-danger py-1 px-2 small mb-2">' + data.mensagem + '</div>';
                    return;
                }

                // Adiciona o novo cargo no dropdown e ja o seleciona automaticamente
                const sel = document.getElementById('fCargo');
                const opt = document.createElement('option');
                opt.value = data.id;
                opt.textContent = data.nome;
                sel.appendChild(opt);
                sel.value = data.id;

                // Limpa e fecha o modal de cadastro rapido
                document.getElementById('crNome').value = '';
                document.getElementById('crDesc').value = '';
                document.getElementById('crComissao').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalCargoRapido')).hide();
            } catch (e) {
                msg.innerHTML = '<div class="alert alert-danger py-1 px-2 small mb-2">Erro ao salvar o cargo. Tente novamente.</div>';
            } finally {
                btn.disabled = false;
            }
        }

        // ===== Helpers AJAX (reutilizados pelos cadastros rapidos hierarquicos) =====
        function alertaErro(m) {
            return '<div class="alert alert-danger py-1 px-2 small mb-2">' + m + '</div>';
        }
        async function postJson(url, body) {
            const token = document.querySelector('#formCargoRapidoToken input[name="__RequestVerificationToken"]').value;
            const resp = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(body)
            });
            return await resp.json();
        }

        // ===== Cadastro rapido de Cidade =====
        async function salvarCidadeRapido() {
            const nome = document.getElementById('cidNome').value.trim();
            const idEstado = document.getElementById('cidEstado').value;
            const msg = document.getElementById('cidMsg');
            const btn = document.getElementById('btnSalvarCidadeRapido');
            msg.innerHTML = '';

            if (!nome) { msg.innerHTML = alertaErro('Informe o nome da cidade.'); return; }
            if (!idEstado) { msg.innerHTML = alertaErro('Selecione o estado.'); return; }

            btn.disabled = true;
            try {
                const data = await postJson('?handler=CidadeRapido', { nmCidade: nome, idEstado: parseInt(idEstado) });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }

                // Adiciona no dropdown de Cidade do funcionario e ja seleciona
                const sel = document.getElementById('fCidade');
                const opt = document.createElement('option');
                opt.value = data.id;
                opt.textContent = data.nome + ' / ' + data.uf;
                sel.appendChild(opt);
                sel.value = data.id;

                document.getElementById('cidNome').value = '';
                document.getElementById('cidEstado').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalCidadeRapido')).hide();
            } catch (e) {
                msg.innerHTML = alertaErro('Erro ao salvar a cidade. Tente novamente.');
            } finally {
                btn.disabled = false;
            }
        }

        // ===== Cadastro rapido de Estado =====
        async function salvarEstadoRapido() {
            const nome = document.getElementById('estNome').value.trim();
            const uf = document.getElementById('estUF').value.trim().toUpperCase();
            const idPais = document.getElementById('estPais').value;
            const msg = document.getElementById('estMsg');
            const btn = document.getElementById('btnSalvarEstadoRapido');
            msg.innerHTML = '';

            if (!nome) { msg.innerHTML = alertaErro('Informe o nome do estado.'); return; }
            if (uf.length !== 2) { msg.innerHTML = alertaErro('Informe a UF (2 letras).'); return; }
            if (!idPais) { msg.innerHTML = alertaErro('Selecione o pais.'); return; }

            btn.disabled = true;
            try {
                const data = await postJson('?handler=EstadoRapido', { sgUF: uf, nmEstado: nome, idPais: parseInt(idPais) });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }

                // Adiciona no dropdown de Estado (modal de Cidade) e ja seleciona
                const sel = document.getElementById('cidEstado');
                const opt = document.createElement('option');
                opt.value = data.id;
                opt.textContent = data.nome + ' / ' + data.uf;
                sel.appendChild(opt);
                sel.value = data.id;

                document.getElementById('estNome').value = '';
                document.getElementById('estUF').value = '';
                document.getElementById('estPais').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalEstadoRapido')).hide();
            } catch (e) {
                msg.innerHTML = alertaErro('Erro ao salvar o estado. Tente novamente.');
            } finally {
                btn.disabled = false;
            }
        }

        // ===== Cadastro rapido de Pais =====
        async function salvarPaisRapido() {
            const nome = document.getElementById('paisNome').value.trim();
            const sigla = document.getElementById('paisSigla').value.trim().toUpperCase();
            const ddi = document.getElementById('paisDDI').value.trim();
            const moeda = document.getElementById('paisMoeda').value.trim();
            const msg = document.getElementById('paisMsg');
            const btn = document.getElementById('btnSalvarPaisRapido');
            msg.innerHTML = '';

            if (!nome) { msg.innerHTML = alertaErro('Informe o nome do pais.'); return; }
            if (!sigla) { msg.innerHTML = alertaErro('Informe a sigla do pais.'); return; }

            btn.disabled = true;
            try {
                const data = await postJson('?handler=PaisRapido', { nmPais: nome, sgPais: sigla, nrDDI: ddi || null, dsMoeda: moeda || null });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }

                // Adiciona no dropdown de Pais (modal de Estado) e ja seleciona
                const sel = document.getElementById('estPais');
                const opt = document.createElement('option');
                opt.value = data.id;
                opt.textContent = data.nome;
                sel.appendChild(opt);
                sel.value = data.id;

                document.getElementById('paisNome').value = '';
                document.getElementById('paisSigla').value = '';
                document.getElementById('paisDDI').value = '';
                document.getElementById('paisMoeda').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalPaisRapido')).hide();
            } catch (e) {
                msg.innerHTML = alertaErro('Erro ao salvar o pais. Tente novamente.');
            } finally {
                btn.disabled = false;
            }
        }

        // ===== Busca de Funcionario (filtros na pagina -> atualiza a grid principal via AJAX) =====
        let resultadosBusca = [];

        // Mascara de CPF no filtro + Enter dispara a busca
        aplicarMascara('buscaCpf', mascaraCPF);
        ['buscaId', 'buscaNome', 'buscaApelido', 'buscaCpf'].forEach(id => {
            document.getElementById(id)?.addEventListener('keydown', e => {
                if (e.key === 'Enter') { e.preventDefault(); buscarFuncionarios(); }
            });
        });

        function statusBadge(ativo) {
            return ativo
                ? '<span class="badge-status badge-ativo">Ativo</span>'
                : '<span class="badge-status badge-inativo">Inativo</span>';
        }

        function montarLinha(f, i, token) {
            const adm = f.adm ? f.adm.split('-').reverse().join('/') : '';
            const com = (f.com !== null && f.com !== undefined) ? f.com + '%' : '-';
            return '<tr>' +
                '<td>' + f.id + '</td>' +
                '<td><strong>' + (f.nome || '') + '</strong></td>' +
                '<td>' + mascaraCPF(f.cpf || '') + '</td>' +
                '<td>' + (f.cargoNome || '-') + '</td>' +
                '<td>' + (f.tel ? mascaraTelefone(f.tel) : '-') + '</td>' +
                '<td>' + adm + '</td>' +
                '<td>' + com + '</td>' +
                '<td>' + statusBadge(f.ativo) + '</td>' +
                '<td class="text-center">' +
                    '<button class="btn btn-icon btn-outline-primary" title="Editar" onclick="abrirEdicao(' + i + ')"><i class="bi bi-pencil"></i></button> ' +
                    '<form method="post" action="?handler=Delete" class="d-inline" onsubmit="return confirm(\'Deseja realmente excluir este funcionario?\')">' +
                        '<input type="hidden" name="__RequestVerificationToken" value="' + token + '">' +
                        '<input type="hidden" name="id" value="' + f.id + '">' +
                        '<button type="submit" class="btn btn-icon btn-outline-danger" title="Excluir"><i class="bi bi-trash"></i></button>' +
                    '</form>' +
                '</td>' +
            '</tr>';
        }

        async function buscarFuncionarios() {
            const tbody = document.querySelector('#tblFuncionarios tbody');
            const id = document.getElementById('buscaId').value.trim();
            const nome = document.getElementById('buscaNome').value.trim();
            const apelido = document.getElementById('buscaApelido').value.trim();
            const cpf = document.getElementById('buscaCpf').value.replace(/\D/g, '');
            const inativos = document.getElementById('buscaInativos').checked;

            const params = new URLSearchParams();
            if (id) params.append('id', id);
            if (nome) params.append('nome', nome);
            if (apelido) params.append('apelido', apelido);
            if (cpf) params.append('cpf', cpf);
            params.append('incluirInativos', inativos);

            tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-3">Buscando...</td></tr>';
            try {
                const resp = await fetch('?handler=BuscarFuncionarios&' + params.toString());
                resultadosBusca = await resp.json();

                const contador = document.getElementById('contadorRegistros');
                if (contador) contador.textContent = resultadosBusca.length + ' registros encontrados';

                if (!resultadosBusca.length) {
                    tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-4">Nenhum funcionario encontrado</td></tr>';
                    return;
                }

                const token = document.querySelector('#formCargoRapidoToken input[name="__RequestVerificationToken"]').value;
                tbody.innerHTML = resultadosBusca.map((f, i) => montarLinha(f, i, token)).join('');
            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-center text-danger py-4">Erro ao buscar. Tente novamente.</td></tr>';
            }
        }

        function abrirEdicao(i) {
            const f = resultadosBusca[i];
            editarFunc(
                f.id, f.nome || '', f.cpf || '', f.tel || '', f.email || '',
                f.end || '', f.bairro || '', (f.idCidade ?? ''), f.cep || '',
                f.nasc || '', f.adm || '', f.dem || '', (f.idCargo ?? ''),
                (f.sal ?? ''), (f.com ?? ''), f.obs || '', (f.ativo ? 'True' : 'False'),
                f.apelido || '', f.rg || '', f.numero || '', f.complemento || '', f.sexo || ''
            );
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalFuncionario')).show();
        }
    </script>
}
