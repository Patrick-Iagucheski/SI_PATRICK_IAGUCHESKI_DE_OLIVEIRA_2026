@page
@model WebAppERP.Pages.Cadastro.ClientesModel
@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">Clientes</h1>
        <p class="page-subtitle">Gerencie os clientes cadastrados no sistema</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCliente" onclick="limparForm()">
        <i class="bi bi-plus-lg me-1"></i> Novo Cliente
    </button>
</div>

<!-- Filtros -->
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="row g-2 align-items-center">
            <div class="col-md-4">
                <div class="search-box">
                    <i class="bi bi-search search-icon"></i>
                    <input type="text" class="form-control" placeholder="Buscar por nome, CPF ou e-mail..." id="searchInput" />
                </div>
            </div>
            <div class="col-md-2">
                <select class="form-select" id="filterStatus">
                    <option value="">Todos os Status</option>
                    <option value="ativo">Ativo</option>
                    <option value="inativo">Inativo</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Tabela -->
<div class="table-container">
    <div class="table-header">
        <h5><i class="bi bi-people-fill me-2"></i>Lista de Clientes</h5>
        <span class="text-muted small">@Model.Clientes.Count registros encontrados</span>
    </div>
    <div class="table-responsive">
        <table class="table" id="tblClientes">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>CPF</th>
                    <th>Telefone</th>
                    <th>E-mail</th>
                    <th>Cidade</th>
                    <th>Status</th>
                    <th class="text-center">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Clientes.Any())
                {
                    @foreach (var c in Model.Clientes)
                    {
                        <tr>
                            <td>@c.IdCliente</td>
                            <td><strong>@c.NmCliente</strong></td>
                            <td>@(c.NrCpf ?? "-")</td>
                            <td>@(c.NrTelefone ?? "-")</td>
                            <td>@(c.DsEmail ?? "-")</td>
                            <td>@(c.Cidade != null ? $"{c.Cidade.NmCidade}/{c.Cidade.Estado?.SgUF}" : "-")</td>
                            <td>
                                @if (c.FlAtivo)
                                {
                                    <span class="badge-status badge-ativo">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inativo">Inativo</span>
                                }
                            </td>
                            <td class="text-center">
                                <button class="btn btn-icon btn-outline-primary" title="Editar"
                                        data-bs-toggle="modal" data-bs-target="#modalCliente"
                                        onclick="editarCliente(@c.IdCliente, '@c.NmCliente.Replace("'", "\\'")','@c.NrCpf','@c.NrTelefone','@c.DsEmail','@c.DsEndereco?.Replace("'", "\\'")','@c.DsBairro?.Replace("'", "\\'")','@(c.IdCidade?.ToString() ?? "")','@c.NrCEP','@(c.DtNascimento?.ToString("yyyy-MM-dd") ?? "")','@c.DsSexo','@c.DsObservacao?.Replace("'", "\\'")','@c.FlAtivo')">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Deseja realmente excluir este cliente?')">
                                    <input type="hidden" name="id" value="@c.IdCliente" />
                                    <button type="submit" class="btn btn-icon btn-outline-danger" title="Excluir">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Nenhum cliente cadastrado</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Novo/Editar Cliente -->
<div class="modal fade" id="modalCliente" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle"><i class="bi bi-person-plus me-2"></i>Novo Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="ClienteForm.IdCliente" id="formIdCliente" />
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label class="form-label">Nome Completo *</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NmCliente" id="formNmCliente" required />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">CPF</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrCpf" id="formNrCpf" placeholder="000.000.000-00" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Telefone</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrTelefone" id="formNrTelefone" placeholder="(00) 00000-0000" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" asp-for="ClienteForm.DsEmail" id="formDsEmail" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Data de Nascimento</label>
                            <input type="date" class="form-control" asp-for="ClienteForm.DtNascimento" id="formDtNascimento" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Sexo</label>
                            <select class="form-select" asp-for="ClienteForm.DsSexo" id="formDsSexo">
                                <option value="">Selecione</option>
                                <option value="M">Masculino</option>
                                <option value="F">Feminino</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">CEP</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrCEP" id="formNrCEP" placeholder="00000-000" />
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">Endereco</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.DsEndereco" id="formDsEndereco" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Bairro</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.DsBairro" id="formDsBairro" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cidade</label>
                            <select class="form-select" asp-for="ClienteForm.IdCidade" id="formIdCidade">
                                <option value="">Selecione a cidade</option>
                                @foreach (var cidade in Model.Cidades)
                                {
                                    <option value="@cidade.IdCidade">@cidade.NmCidade / @cidade.Estado?.SgUF</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Status</label>
                            <select class="form-select" asp-for="ClienteForm.FlAtivo" id="formFlAtivo">
                                <option value="true">Ativo</option>
                                <option value="false">Inativo</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Observacoes</label>
                            <textarea class="form-control" rows="2" asp-for="ClienteForm.DsObservacao" id="formDsObservacao"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput')?.addEventListener('input', function () {
            const filter = this.value.toLowerCase();
            document.querySelectorAll('#tblClientes tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(filter) ? '' : 'none';
            });
        });

        function limparForm() {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-person-plus me-2"></i>Novo Cliente';
            document.getElementById('formIdCliente').value = '0';
            document.getElementById('formNmCliente').value = '';
            document.getElementById('formNrCpf').value = '';
            document.getElementById('formNrTelefone').value = '';
            document.getElementById('formDsEmail').value = '';
            document.getElementById('formDsEndereco').value = '';
            document.getElementById('formDsBairro').value = '';
            document.getElementById('formIdCidade').value = '';
            document.getElementById('formNrCEP').value = '';
            document.getElementById('formDtNascimento').value = '';
            document.getElementById('formDsSexo').value = '';
            document.getElementById('formDsObservacao').value = '';
            document.getElementById('formFlAtivo').value = 'true';
        }

        function editarCliente(id, nome, cpf, tel, email, end, bairro, cidade, cep, nasc, sexo, obs, ativo) {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Editar Cliente';
            document.getElementById('formIdCliente').value = id;
            document.getElementById('formNmCliente').value = nome;
            document.getElementById('formNrCpf').value = cpf;
            document.getElementById('formNrTelefone').value = tel;
            document.getElementById('formDsEmail').value = email;
            document.getElementById('formDsEndereco').value = end;
            document.getElementById('formDsBairro').value = bairro;
            document.getElementById('formIdCidade').value = cidade;
            document.getElementById('formNrCEP').value = cep;
            document.getElementById('formDtNascimento').value = nasc;
            document.getElementById('formDsSexo').value = sexo;
            document.getElementById('formDsObservacao').value = obs;
            document.getElementById('formFlAtivo').value = ativo === 'True' ? 'true' : 'false';
        }
    </script>
}
