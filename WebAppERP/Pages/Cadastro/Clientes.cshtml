<!-- Token antiforgery para as chamadas AJAX (form isolado, fora do form de cliente) -->
<form id="formTokenAjax" class="d-none">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script>
        // ===== Mascaras (somente exibicao; no banco salva so numeros) =====
        function mascaraCPF(v) {
            return v.replace(/\D/g, '').slice(0, 11)
                .replace(/^(\d{3})(\d)/, '$1.$2')
                .replace(/^(\d{3})\.(\d{3})(\d)/, '$1.$2.$3')
                .replace(/\.(\d{3})(\d)/, '.$1-$2');
        }
        function mascaraCNPJ(v) {
            return v.replace(/\D/g, '').slice(0, 14)
                .replace(/^(\d{2})(\d)/, '$1.$2')
                .replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3')
                .replace(/\.(\d{3})(\d)/, '.$1/$2')
                .replace(/(\d{4})(\d)/, '$1-$2');
        }
        function mascaraCEP(v) {
            return v.replace(/\D/g, '').slice(0, 8).replace(/^(\d{5})(\d)/, '$1-$2');
        }
        function mascaraTelefone(v) {
            v = v.replace(/\D/g, '').slice(0, 11);
            if (v.length > 10)
                return v.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
            return v.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3').trim();
        }
        function mascaraRG(v) {
            return v.replace(/\D/g, '').slice(0, 9)
                .replace(/^(\d{2})(\d)/, '$1.$2')
                .replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3')
                .replace(/\.(\d{3})(\d)/, '.$1-$2');
        }
        function aplicarMascara(id, fn) {
            const el = document.getElementById(id);
            el?.addEventListener('input', () => { el.value = fn(el.value); });
        }
        aplicarMascara('formNrCpf', mascaraCPF);
        aplicarMascara('formNrCnpj', mascaraCNPJ);
        aplicarMascara('formNrCEP', mascaraCEP);
        aplicarMascara('formNrTelefone', mascaraTelefone);
        aplicarMascara('formNrRG', mascaraRG);

        // ===== Validacao de CPF / CNPJ (digitos verificadores) =====
        function cpfValido(cpf) {
            const d = (cpf || '').replace(/\D/g, '');
            if (d.length !== 11 || /^(\d)\1{10}$/.test(d)) return false;
            const calc = (qtd) => {
                let s = 0;
                for (let i = 0; i < qtd; i++) s += parseInt(d[i]) * (qtd + 1 - i);
                const r = s % 11;
                return r < 2 ? 0 : 11 - r;
            };
            return calc(9) === parseInt(d[9]) && calc(10) === parseInt(d[10]);
        }
        function cnpjValido(cnpj) {
            const d = (cnpj || '').replace(/\D/g, '');
            if (d.length !== 14 || /^(\d)\1{13}$/.test(d)) return false;
            const calc = (qtd, pesos) => {
                let s = 0;
                for (let i = 0; i < qtd; i++) s += parseInt(d[i]) * pesos[i];
                const r = s % 11;
                return r < 2 ? 0 : 11 - r;
            };
            const p1 = [5, 4, 3, 2, 9, 8, 7, 6, 5, 4, 3, 2];
            const p2 = [6, 5, 4, 3, 2, 9, 8, 7, 6, 5, 4, 3, 2];
            return calc(12, p1) === parseInt(d[12]) && calc(13, p2) === parseInt(d[13]);
        }

        // ===== Tipo de Pessoa: alterna o documento exibido =====
        function toggleTipoPessoa() {
            const tipo = document.getElementById('formTpPessoa').value;
            const wrapCpf = document.getElementById('wrapCpf');
            const wrapCnpj = document.getElementById('wrapCnpj');
            const wrapDoc = document.getElementById('wrapDoc');
            const lblNome = document.getElementById('lblNome');

            wrapCpf.classList.toggle('d-none', tipo !== 'F');
            wrapCnpj.classList.toggle('d-none', tipo !== 'J');
            wrapDoc.classList.toggle('d-none', tipo !== 'E');

            lblNome.textContent = tipo === 'J' ? 'Razao Social *' : 'Nome Completo *';
        }

        // ===== Validacao do formulario antes de enviar =====
        document.querySelector('#modalCliente form')?.addEventListener('submit', function (e) {
            const tipo = document.getElementById('formTpPessoa').value;
            const cpf = document.getElementById('formNrCpf').value;
            const cnpj = document.getElementById('formNrCnpj').value;
            const email = document.getElementById('formDsEmail').value.trim();

            if (tipo === 'F' && cpf.replace(/\D/g, '') && !cpfValido(cpf)) {
                e.preventDefault();
                alert('CPF invalido. Verifique os numeros informados.');
                return;
            }
            if (tipo === 'J' && cnpj.replace(/\D/g, '') && !cnpjValido(cnpj)) {
                e.preventDefault();
                alert('CNPJ invalido. Verifique os numeros informados.');
                return;
            }
            if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) {
                e.preventDefault();
                alert('E-mail invalido. Verifique o formato (exemplo: nome@@dominio.com).');
                return;
            }
        });

        function limparForm() {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-person-plus me-2"></i>Novo Cliente';
            ['formNmCliente','formNrCpf','formNrCnpj','formNrDocumento','formNrRG','formNrTelefone','formDsEmail','formDsEndereco','formNrNumero','formDsComplemento','formDsBairro','formIdCidade','formNrCEP','formDtNascimento','formDsSexo','formDsObservacao','formCodigoDisplay'].forEach(id => {
                document.getElementById(id).value = '';
            });
            document.getElementById('formIdCliente').value = '0';
            document.getElementById('formTpPessoa').value = 'F';
            document.getElementById('formFlAtivo').value = 'true';
            toggleTipoPessoa();
        }

        function editarCliente(id, nome, tipo, cpf, cnpj, doc, rg, tel, email, end, numero, complemento, bairro, cidade, cep, nasc, sexo, obs, ativo) {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Editar Cliente';
            document.getElementById('formIdCliente').value = id;
            document.getElementById('formCodigoDisplay').value = id;
            document.getElementById('formNmCliente').value = nome;
            document.getElementById('formTpPessoa').value = tipo || 'F';
            document.getElementById('formNrCpf').value = mascaraCPF(cpf || '');
            document.getElementById('formNrCnpj').value = mascaraCNPJ(cnpj || '');
            document.getElementById('formNrDocumento').value = doc || '';
            document.getElementById('formNrRG').value = mascaraRG(rg || '');
            document.getElementById('formNrTelefone').value = mascaraTelefone(tel || '');
            document.getElementById('formDsEmail').value = email || '';
            document.getElementById('formDsEndereco').value = end || '';
            document.getElementById('formNrNumero').value = numero || '';
            document.getElementById('formDsComplemento').value = complemento || '';
            document.getElementById('formDsBairro').value = bairro || '';
            document.getElementById('formIdCidade').value = cidade || '';
            document.getElementById('formNrCEP').value = mascaraCEP(cep || '');
            document.getElementById('formDtNascimento').value = nasc || '';
            document.getElementById('formDsSexo').value = sexo || '';
            document.getElementById('formDsObservacao').value = obs || '';
            document.getElementById('formFlAtivo').value = ativo === 'True' ? 'true' : 'false';
            toggleTipoPessoa();
        }

        // ===== Helpers AJAX (reutilizados pelos cadastros rapidos hierarquicos) =====
        function alertaErro(m) {
            return '<div class="alert alert-danger py-1 px-2 small mb-2">' + m + '</div>';
        }
        async function postJson(url, body) {
            const token = document.querySelector('#formTokenAjax input[name="__RequestVerificationToken"]').value;
            const resp = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token },
                body: JSON.stringify(body)
            });
            return await resp.json();
        }

        // ===== Cadastro rapido de Cidade =====
        async function salvarCidadeRapido() {
            const nome = document.getElementById('cidNome').value.trim();
            const idEstado = document.getElementById('cidEstado').value;
            const msg = document.getElementById('cidMsg');
            const btn = document.getElementById('btnSalvarCidadeRapido');
            msg.innerHTML = '';

            if (!nome) { msg.innerHTML = alertaErro('Informe o nome da cidade.'); return; }
            if (!idEstado) { msg.innerHTML = alertaErro('Selecione o estado.'); return; }

            btn.disabled = true;
            try {
                const data = await postJson('?handler=CidadeRapido', { nmCidade: nome, idEstado: parseInt(idEstado) });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }

                const sel = document.getElementById('formIdCidade');
                const opt = document.createElement('option');
                opt.value = data.id;
                opt.textContent = data.nome + ' / ' + data.uf;
                sel.appendChild(opt);
                sel.value = data.id;

                document.getElementById('cidNome').value = '';
                document.getElementById('cidEstado').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalCidadeRapido')).hide();
            } catch (e) {
                msg.innerHTML = alertaErro('Erro ao salvar a cidade. Tente novamente.');
            } finally {
                btn.disabled = false;
            }
        }

        // ===== Cadastro rapido de Estado =====
        async function salvarEstadoRapido() {
            const nome = document.getElementById('estNome').value.trim();
            const uf = document.getElementById('estUF').value.trim().toUpperCase();
            const idPais = document.getElementById('estPais').value;
            const msg = document.getElementById('estMsg');
            const btn = document.getElementById('btnSalvarEstadoRapido');
            msg.innerHTML = '';

            if (!nome) { msg.innerHTML = alertaErro('Informe o nome do estado.'); return; }
            if (uf.length !== 2) { msg.innerHTML = alertaErro('Informe a UF (2 letras).'); return; }
            if (!idPais) { msg.innerHTML = alertaErro('Selecione o pais.'); return; }

            btn.disabled = true;
            try {
                const data = await postJson('?handler=EstadoRapido', { sgUF: uf, nmEstado: nome, idPais: parseInt(idPais) });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }

                const sel = document.getElementById('cidEstado');
                const opt = document.createElement('option');
                opt.value = data.id;
                opt.textContent = data.nome + ' / ' + data.uf;
                sel.appendChild(opt);
                sel.value = data.id;

                document.getElementById('estNome').value = '';
                document.getElementById('estUF').value = '';
                document.getElementById('estPais').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalEstadoRapido')).hide();
            } catch (e) {
                msg.innerHTML = alertaErro('Erro ao salvar o estado. Tente novamente.');
            } finally {
                btn.disabled = false;
            }
        }

        // ===== Cadastro rapido de Pais =====
        async function salvarPaisRapido() {
            const nome = document.getElementById('paisNome').value.trim();
            const sigla = document.getElementById('paisSigla').value.trim().toUpperCase();
            const ddi = document.getElementById('paisDDI').value.trim();
            const moeda = document.getElementById('paisMoeda').value.trim();
            const msg = document.getElementById('paisMsg');
            const btn = document.getElementById('btnSalvarPaisRapido');
            msg.innerHTML = '';

            if (!nome) { msg.innerHTML = alertaErro('Informe o nome do pais.'); return; }
            if (!sigla) { msg.innerHTML = alertaErro('Informe a sigla do pais.'); return; }

            btn.disabled = true;
            try {
                const data = await postJson('?handler=PaisRapido', { nmPais: nome, sgPais: sigla, nrDDI: ddi || null, dsMoeda: moeda || null });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }

                const sel = document.getElementById('estPais');
                const opt = document.createElement('option');
                opt.value = data.id;
                opt.textContent = data.nome;
                sel.appendChild(opt);
                sel.value = data.id;

                document.getElementById('paisNome').value = '';
                document.getElementById('paisSigla').value = '';
                document.getElementById('paisDDI').value = '';
                document.getElementById('paisMoeda').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalPaisRapido')).hide();
            } catch (e) {
                msg.innerHTML = alertaErro('Erro ao salvar o pais. Tente novamente.');
            } finally {
                btn.disabled = false;
            }
        }

        // ===== Busca de Clientes (filtros na pagina -> atualiza a grid via AJAX) =====
        let resultadosBusca = [];

        aplicarMascara('buscaDocumento', mascaraCPF);
        ['buscaId', 'buscaNome', 'buscaDocumento', 'buscaEmail'].forEach(id => {
            document.getElementById(id)?.addEventListener('keydown', e => {
                if (e.key === 'Enter') { e.preventDefault(); buscarClientes(); }
            });
        });

        function statusBadge(ativo) {
            return ativo
                ? '<span class="badge-status badge-ativo">Ativo</span>'
                : '<span class="badge-status badge-inativo">Inativo</span>';
        }

        function tipoLabel(t) {
            if (t === 'J') return 'Juridica';
            if (t === 'E') return 'Estrangeiro';
            return 'Fisica';
        }

        function documentoExibicao(f) {
            if (f.tipoPessoa === 'J') return f.cnpj ? mascaraCNPJ(f.cnpj) : '-';
            if (f.tipoPessoa === 'E') return f.documento || '-';
            return f.cpf ? mascaraCPF(f.cpf) : '-';
        }

        function montarLinha(f, i, token) {
            return '<tr>' +
                '<td>' + f.id + '</td>' +
                '<td><strong>' + (f.nome || '') + '</strong></td>' +
                '<td>' + tipoLabel(f.tipoPessoa) + '</td>' +
                '<td>' + documentoExibicao(f) + '</td>' +
                '<td>' + (f.tel ? mascaraTelefone(f.tel) : '-') + '</td>' +
                '<td>' + (f.email || '-') + '</td>' +
                '<td>' + (f.cidadeNome || '-') + '</td>' +
                '<td>' + statusBadge(f.ativo) + '</td>' +
                '<td class="text-center">' +
                    '<button class="btn btn-icon btn-outline-primary" title="Editar" onclick="abrirEdicao(' + i + ')"><i class="bi bi-pencil"></i></button> ' +
                    '<form method="post" action="?handler=Delete" class="d-inline" onsubmit="return confirm(\'Deseja realmente excluir este cliente?\')">' +
                        '<input type="hidden" name="__RequestVerificationToken" value="' + token + '">' +
                        '<input type="hidden" name="id" value="' + f.id + '">' +
                        '<button type="submit" class="btn btn-icon btn-outline-danger" title="Excluir"><i class="bi bi-trash"></i></button>' +
                    '</form>' +
                '</td>' +
            '</tr>';
        }

        async function buscarClientes() {
            const tbody = document.querySelector('#tblClientes tbody');
            const id = document.getElementById('buscaId').value.trim();
            const nome = document.getElementById('buscaNome').value.trim();
            const documento = document.getElementById('buscaDocumento').value.trim();
            const email = document.getElementById('buscaEmail').value.trim();
            const inativos = document.getElementById('buscaInativos').checked;

            const params = new URLSearchParams();
            if (id) params.append('id', id);
            if (nome) params.append('nome', nome);
            if (documento) params.append('documento', documento);
            if (email) params.append('email', email);
            params.append('incluirInativos', inativos);

            tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-3">Buscando...</td></tr>';
            try {
                const resp = await fetch('?handler=BuscarClientes&' + params.toString());
                resultadosBusca = await resp.json();

                const contador = document.getElementById('contadorRegistros');
                if (contador) contador.textContent = resultadosBusca.length + ' registros encontrados';

                if (!resultadosBusca.length) {
                    tbody.innerHTML = '<tr><td colspan="9" class="text-center text-muted py-4">Nenhum cliente encontrado</td></tr>';
                    return;
                }

                const token = document.querySelector('#formTokenAjax input[name="__RequestVerificationToken"]').value;
                tbody.innerHTML = resultadosBusca.map((f, i) => montarLinha(f, i, token)).join('');
            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="9" class="text-center text-danger py-4">Erro ao buscar. Tente novamente.</td></tr>';
            }
        }

        function abrirEdicao(i) {
            const f = resultadosBusca[i];
            editarCliente(
                f.id, f.nome || '', f.tipoPessoa || 'F', f.cpf || '', f.cnpj || '', f.documento || '',
                f.rg || '', f.tel || '', f.email || '', f.end || '', f.numero || '', f.complemento || '',
                f.bairro || '', (f.idCidade ?? ''), f.cep || '', f.nasc || '', f.sexo || '',
                f.obs || '', (f.ativo ? 'True' : 'False')
            );
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalCliente')).show();
        }
    </script>
}
