@page
@model WebAppERP.Pages.Cadastro.ClientesModel
@{
    ViewData["Title"] = "Clientes";

    string FormatarCPF(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        return d.Length == 11
            ? $"{d[..3]}.{d.Substring(3, 3)}.{d.Substring(6, 3)}-{d.Substring(9, 2)}"
            : (string.IsNullOrEmpty(v) ? "" : v);
    }

    string FormatarCNPJ(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        return d.Length == 14
            ? $"{d[..2]}.{d.Substring(2, 3)}.{d.Substring(5, 3)}/{d.Substring(8, 4)}-{d.Substring(12, 2)}"
            : (string.IsNullOrEmpty(v) ? "" : v);
    }

    string FormatarTelefone(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        if (d.Length == 11) return $"({d[..2]}) {d.Substring(2, 5)}-{d.Substring(7, 4)}";
        if (d.Length == 10) return $"({d[..2]}) {d.Substring(2, 4)}-{d.Substring(6, 4)}";
        return string.IsNullOrEmpty(v) ? "-" : v;
    }

    string TipoPessoaLabel(string? t) => t switch
    {
        "J" => "Juridica",
        "E" => "Estrangeiro",
        _ => "Fisica"
    };

    string DocumentoExibicao(WebAppERP.Models.GerCliente c) => c.TpPessoa switch
    {
        "J" => FormatarCNPJ(c.NrCnpj),
        "E" => c.NrDocumento ?? "",
        _ => FormatarCPF(c.NrCpf)
    };
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">Clientes</h1>
        <p class="page-subtitle">Gerencie os clientes cadastrados no sistema</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalCliente" onclick="limparForm()">
        <i class="bi bi-plus-lg me-1"></i> Novo Cliente
    </button>
</div>

@if (TempData["ErroCliente"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["ErroCliente"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filtros de busca (todos opcionais e combinaveis) -->
<div class="card mb-3">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">ID</label>
                <input type="number" class="form-control" id="buscaId" min="1" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Nome</label>
                <input type="text" class="form-control" id="buscaNome" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">CPF / CNPJ / Documento</label>
                <input type="text" class="form-control" id="buscaDocumento" autocomplete="off" />
            </div>
            <div class="col-md-4">
                <label class="form-label small mb-1">E-mail</label>
                <input type="text" class="form-control" id="buscaEmail" autocomplete="off" />
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="buscaInativos" onchange="buscarClientes()" />
                <label class="form-check-label" for="buscaInativos">Exibir Clientes Inativos</label>
            </div>
            <button type="button" class="btn btn-primary" onclick="buscarClientes()">
                <i class="bi bi-search me-1"></i>Buscar
            </button>
        </div>
    </div>
</div>

<!-- Tabela -->
<div class="table-container">
    <div class="table-header">
        <h5><i class="bi bi-people-fill me-2"></i>Lista de Clientes</h5>
        <span class="text-muted small" id="contadorRegistros">@Model.Clientes.Count registros encontrados</span>
    </div>
    <div class="table-responsive">
        <table class="table" id="tblClientes">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nome</th>
                    <th>Tipo</th>
                    <th>CPF / CNPJ</th>
                    <th>Telefone</th>
                    <th>E-mail</th>
                    <th>Cidade</th>
                    <th>Status</th>
                    <th class="text-center">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Clientes.Any())
                {
                    @foreach (var c in Model.Clientes)
                    {
                        <tr>
                            <td>@c.IdCliente</td>
                            <td><strong>@c.NmCliente</strong></td>
                            <td>@TipoPessoaLabel(c.TpPessoa)</td>
                            <td>@(string.IsNullOrEmpty(DocumentoExibicao(c)) ? "-" : DocumentoExibicao(c))</td>
                            <td>@FormatarTelefone(c.NrTelefone)</td>
                            <td>@(c.DsEmail ?? "-")</td>
                            <td>@(c.Cidade != null ? $"{c.Cidade.NmCidade}/{c.Cidade.Estado?.SgUF}" : "-")</td>
                            <td>
                                @if (c.FlAtivo)
                                {
                                    <span class="badge-status badge-ativo">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inativo">Inativo</span>
                                }
                            </td>
                            <td class="text-center">
                                <button class="btn btn-icon btn-outline-primary" title="Editar"
                                        data-bs-toggle="modal" data-bs-target="#modalCliente"
                                        onclick="editarCliente(@c.IdCliente,'@c.NmCliente.Replace("'", "\\'")','@c.TpPessoa','@c.NrCpf','@c.NrCnpj','@c.NrDocumento?.Replace("'", "\\'")','@c.NrRG','@c.NrTelefone','@c.DsEmail','@c.DsEndereco?.Replace("'", "\\'")','@c.NrNumero','@c.DsComplemento?.Replace("'", "\\'")','@c.DsBairro?.Replace("'", "\\'")','@(c.IdCidade?.ToString() ?? "")','@c.NrCEP','@(c.DtNascimento?.ToString("yyyy-MM-dd") ?? "")','@c.DsSexo','@c.DsObservacao?.Replace("'", "\\'")','@c.FlAtivo')">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Deseja realmente excluir este cliente?')">
                                    <input type="hidden" name="id" value="@c.IdCliente" />
                                    <button type="submit" class="btn btn-icon btn-outline-danger" title="Excluir">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">Nenhum cliente cadastrado</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Novo/Editar Cliente -->
<div class="modal fade" id="modalCliente" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle"><i class="bi bi-person-plus me-2"></i>Novo Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="ClienteForm.IdCliente" id="formIdCliente" />
                    <div class="row g-3">
                        <!-- Codigo (somente leitura) | Tipo de Pessoa | Nome -->
                        <div class="col-md-2">
                            <label class="form-label">Codigo</label>
                            <input type="text" class="form-control bg-light" id="formCodigoDisplay" placeholder="(novo)" readonly />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tipo de Pessoa *</label>
                            <select class="form-select" asp-for="ClienteForm.TpPessoa" id="formTpPessoa" onchange="toggleTipoPessoa()">
                                <option value="F">Pessoa Fisica</option>
                                <option value="J">Pessoa Juridica</option>
                                <option value="E">Estrangeiro / Outro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" id="lblNome">Nome Completo *</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NmCliente" id="formNmCliente" maxlength="200" required />
                        </div>

                        <!-- Documento (CPF / CNPJ / Outro) | RG | Sexo | Nascimento -->
                        <div class="col-md-3" id="wrapCpf">
                            <label class="form-label">CPF</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrCpf" id="formNrCpf" maxlength="14" placeholder="000.000.000-00" />
                        </div>
                        <div class="col-md-3 d-none" id="wrapCnpj">
                            <label class="form-label">CNPJ</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrCnpj" id="formNrCnpj" maxlength="18" placeholder="00.000.000/0000-00" />
                        </div>
                        <div class="col-md-3 d-none" id="wrapDoc">
                            <label class="form-label">Documento</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrDocumento" id="formNrDocumento" maxlength="30" placeholder="Documento" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">RG</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrRG" id="formNrRG" maxlength="12" placeholder="00.000.000-0" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Sexo</label>
                            <select class="form-select" asp-for="ClienteForm.DsSexo" id="formDsSexo">
                                <option value="">Selecione</option>
                                <option value="M">Masculino</option>
                                <option value="F">Feminino</option>
                                <option value="O">Outro</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Data de Nascimento</label>
                            <input type="date" class="form-control" asp-for="ClienteForm.DtNascimento" id="formDtNascimento" />
                        </div>

                        <!-- Telefone | E-mail -->
                        <div class="col-md-4">
                            <label class="form-label">Telefone</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrTelefone" id="formNrTelefone" maxlength="15" placeholder="(00) 00000-0000" />
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">E-mail</label>
                            <input type="email" class="form-control" asp-for="ClienteForm.DsEmail" id="formDsEmail" maxlength="150" />
                        </div>

                        <!-- Endereco | Numero -->
                        <div class="col-md-8">
                            <label class="form-label">Endereco</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.DsEndereco" id="formDsEndereco" maxlength="200" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Numero</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrNumero" id="formNrNumero" maxlength="10" />
                        </div>

                        <!-- Complemento | Bairro -->
                        <div class="col-md-6">
                            <label class="form-label">Complemento</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.DsComplemento" id="formDsComplemento" maxlength="100" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Bairro</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.DsBairro" id="formDsBairro" maxlength="100" />
                        </div>

                        <!-- Cidade (cadastro rapido) | CEP | Status -->
                        <div class="col-md-6">
                            <label class="form-label">Cidade</label>
                            <div class="input-group">
                                <select class="form-select" asp-for="ClienteForm.IdCidade" id="formIdCidade">
                                    <option value="">Selecione</option>
                                    @foreach (var cidade in Model.Cidades)
                                    {
                                        <option value="@cidade.IdCidade">@cidade.NmCidade / @cidade.Estado?.SgUF</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#modalCidadeRapido" title="Cadastrar nova cidade">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">CEP</label>
                            <input type="text" class="form-control" asp-for="ClienteForm.NrCEP" id="formNrCEP" maxlength="9" placeholder="00000-000" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" asp-for="ClienteForm.FlAtivo" id="formFlAtivo">
                                <option value="true">Ativo</option>
                                <option value="false">Inativo</option>
                            </select>
                        </div>

                        <!-- Observacoes -->
                        <div class="col-12">
                            <label class="form-label">Observacoes</label>
                            <textarea class="form-control" rows="2" asp-for="ClienteForm.DsObservacao" id="formDsObservacao" maxlength="500"></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

