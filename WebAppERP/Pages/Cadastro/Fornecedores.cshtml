<!-- Token antiforgery para as chamadas AJAX -->
<form id="formTokenAjax" class="d-none">@Html.AntiForgeryToken()</form>

@section Scripts {
    <script>
        // Dados dos fornecedores ja carregados na pagina (para edicao das linhas iniciais)
        const dadosIniciais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Fornecedores.Select(f => new {
            id = f.IdFornecedor, tipoPessoa = f.TpPessoa, razaoSocial = f.DsRazaoSocial, nomeFantasia = f.DsNomeFantasia,
            contatoPrincipal = f.DsContatoPrincipal, cpf = f.NrCpf, cnpj = f.NrCNPJ, documento = f.NrDocumento,
            inscEstadual = f.NrInscEstadual, inscMunicipal = f.NrInscMunicipal, email = f.DsEmail, observacao = f.DsObservacao,
            cep = f.NrCEP, endereco = f.DsEndereco, numero = f.NrNumero, complemento = f.DsComplemento, bairro = f.DsBairro,
            idCidade = f.IdCidade, telefoneFixo = f.NrTelefoneFixo, celular = f.NrCelular, whatsApp = f.NrWhatsApp,
            banco = f.DsBanco, agencia = f.NrAgencia, tipoConta = f.TpConta, conta = f.NrConta, digitoConta = f.NrDigitoConta,
            tipoChavePix = f.TpChavePix, chavePix = f.DsChavePix, ativo = f.FlAtivo
        })));

        let resultadosBusca = [];

        // ===== Mascaras =====
        function mascaraCPF(v) {
            return v.replace(/\D/g, '').slice(0, 11)
                .replace(/^(\d{3})(\d)/, '$1.$2')
                .replace(/^(\d{3})\.(\d{3})(\d)/, '$1.$2.$3')
                .replace(/\.(\d{3})(\d)/, '.$1-$2');
        }
        function mascaraCNPJ(v) {
            return v.replace(/\D/g, '').slice(0, 14)
                .replace(/^(\d{2})(\d)/, '$1.$2')
                .replace(/^(\d{2})\.(\d{3})(\d)/, '$1.$2.$3')
                .replace(/\.(\d{3})(\d)/, '.$1/$2')
                .replace(/(\d{4})(\d)/, '$1-$2');
        }
        function mascaraCEP(v) { return v.replace(/\D/g, '').slice(0, 8).replace(/^(\d{5})(\d)/, '$1-$2'); }
        function mascaraTelefone(v) {
            v = v.replace(/\D/g, '').slice(0, 11);
            if (v.length > 10) return v.replace(/^(\d{2})(\d{5})(\d{4}).*/, '($1) $2-$3');
            return v.replace(/^(\d{2})(\d{4})(\d{0,4}).*/, '($1) $2-$3').trim();
        }
        function aplicarMascara(id, fn) {
            const el = document.getElementById(id);
            el?.addEventListener('input', () => { el.value = fn(el.value); });
        }
        aplicarMascara('formNrCpf', mascaraCPF);
        aplicarMascara('formNrCNPJ', mascaraCNPJ);
        aplicarMascara('formNrCEP', mascaraCEP);
        aplicarMascara('formNrTelefoneFixo', mascaraTelefone);
        aplicarMascara('formNrCelular', mascaraTelefone);
        aplicarMascara('formNrWhatsApp', mascaraTelefone);

        // ===== Validacao de CPF / CNPJ =====
        function cpfValido(cpf) {
            const d = (cpf || '').replace(/\D/g, '');
            if (d.length !== 11 || /^(\d)\1{10}$/.test(d)) return false;
            const calc = (q) => { let s = 0; for (let i = 0; i < q; i++) s += parseInt(d[i]) * (q + 1 - i); const r = s % 11; return r < 2 ? 0 : 11 - r; };
            return calc(9) === parseInt(d[9]) && calc(10) === parseInt(d[10]);
        }
        function cnpjValido(cnpj) {
            const d = (cnpj || '').replace(/\D/g, '');
            if (d.length !== 14 || /^(\d)\1{13}$/.test(d)) return false;
            const p1 = [5,4,3,2,9,8,7,6,5,4,3,2], p2 = [6,5,4,3,2,9,8,7,6,5,4,3,2];
            const calc = (q, p) => { let s = 0; for (let i = 0; i < q; i++) s += parseInt(d[i]) * p[i]; const r = s % 11; return r < 2 ? 0 : 11 - r; };
            return calc(12, p1) === parseInt(d[12]) && calc(13, p2) === parseInt(d[13]);
        }

        // ===== Tipo de Pessoa: alterna o documento exibido =====
        function toggleTipoPessoa() {
            const tipo = document.getElementById('formTpPessoa').value;
            document.getElementById('wrapCnpj').classList.toggle('d-none', tipo !== 'J');
            document.getElementById('wrapCpf').classList.toggle('d-none', tipo !== 'F');
            document.getElementById('wrapDoc').classList.toggle('d-none', !(tipo === 'E' || tipo === 'O'));
            document.getElementById('lblDoc').textContent = tipo === 'E' ? 'Documento Internacional' : 'Documento';
            document.getElementById('lblRazao').textContent = tipo === 'J' ? 'Razao Social *' : 'Nome / Razao Social *';
        }

        // ===== Mascara da chave PIX conforme o tipo =====
        function aplicarMascaraPix() {
            const t = document.getElementById('formTpChavePix').value;
            const el = document.getElementById('formDsChavePix');
            if (t === 'CPF') el.value = mascaraCPF(el.value);
            else if (t === 'CNPJ') el.value = mascaraCNPJ(el.value);
            else if (t === 'CELULAR') el.value = mascaraTelefone(el.value);
        }
        document.getElementById('formDsChavePix')?.addEventListener('input', aplicarMascaraPix);

        // ===== Validacao antes de enviar =====
        document.querySelector('#modalFornecedor form')?.addEventListener('submit', function (e) {
            const tipo = document.getElementById('formTpPessoa').value;
            const cnpj = document.getElementById('formNrCNPJ').value;
            const cpf = document.getElementById('formNrCpf').value;
            const email = document.getElementById('formDsEmail').value.trim();
            if (tipo === 'J' && cnpj.replace(/\D/g, '') && !cnpjValido(cnpj)) { e.preventDefault(); alert('CNPJ invalido. Verifique os numeros informados.'); return; }
            if (tipo === 'F' && cpf.replace(/\D/g, '') && !cpfValido(cpf)) { e.preventDefault(); alert('CPF invalido. Verifique os numeros informados.'); return; }
            if (email && !/^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/.test(email)) { e.preventDefault(); alert('E-mail invalido. Verifique o formato (exemplo: nome@@dominio.com).'); return; }
        });

        function limparForm() {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-truck me-2"></i>Novo Fornecedor';
            ['formDsRazaoSocial','formDsNomeFantasia','formDsContatoPrincipal','formNrCNPJ','formNrCpf','formNrDocumento','formNrInscEstadual','formNrInscMunicipal','formDsObservacao','formNrCEP','formDsEndereco','formNrNumero','formDsComplemento','formDsBairro','formIdCidade','formNrTelefoneFixo','formNrCelular','formNrWhatsApp','formDsEmail','formDsBanco','formNrAgencia','formTpConta','formNrConta','formNrDigitoConta','formTpChavePix','formDsChavePix','formCodigoDisplay'].forEach(id => {
                document.getElementById(id).value = '';
            });
            document.getElementById('formId').value = '0';
            document.getElementById('formTpPessoa').value = 'J';
            document.getElementById('formFlAtivo').value = 'true';
            toggleTipoPessoa();
        }

        function editarFornecedor(f) {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-pencil me-2"></i>Editar Fornecedor';
            document.getElementById('formId').value = f.id;
            document.getElementById('formCodigoDisplay').value = f.id;
            document.getElementById('formTpPessoa').value = f.tipoPessoa || 'J';
            document.getElementById('formDsRazaoSocial').value = f.razaoSocial || '';
            document.getElementById('formDsNomeFantasia').value = f.nomeFantasia || '';
            document.getElementById('formDsContatoPrincipal').value = f.contatoPrincipal || '';
            document.getElementById('formNrCNPJ').value = mascaraCNPJ(f.cnpj || '');
            document.getElementById('formNrCpf').value = mascaraCPF(f.cpf || '');
            document.getElementById('formNrDocumento').value = f.documento || '';
            document.getElementById('formNrInscEstadual').value = f.inscEstadual || '';
            document.getElementById('formNrInscMunicipal').value = f.inscMunicipal || '';
            document.getElementById('formDsEmail').value = f.email || '';
            document.getElementById('formDsObservacao').value = f.observacao || '';
            document.getElementById('formNrCEP').value = mascaraCEP(f.cep || '');
            document.getElementById('formDsEndereco').value = f.endereco || '';
            document.getElementById('formNrNumero').value = f.numero || '';
            document.getElementById('formDsComplemento').value = f.complemento || '';
            document.getElementById('formDsBairro').value = f.bairro || '';
            document.getElementById('formIdCidade').value = f.idCidade || '';
            document.getElementById('formNrTelefoneFixo').value = mascaraTelefone(f.telefoneFixo || '');
            document.getElementById('formNrCelular').value = mascaraTelefone(f.celular || '');
            document.getElementById('formNrWhatsApp').value = mascaraTelefone(f.whatsApp || '');
            document.getElementById('formDsBanco').value = f.banco || '';
            document.getElementById('formNrAgencia').value = f.agencia || '';
            document.getElementById('formTpConta').value = f.tipoConta || '';
            document.getElementById('formNrConta').value = f.conta || '';
            document.getElementById('formNrDigitoConta').value = f.digitoConta || '';
            document.getElementById('formTpChavePix').value = f.tipoChavePix || '';
            document.getElementById('formDsChavePix').value = f.chavePix || '';
            aplicarMascaraPix();
            document.getElementById('formFlAtivo').value = (f.ativo === true || f.ativo === 'True') ? 'true' : 'false';
            toggleTipoPessoa();
        }

        function editarPorId(id) {
            const f = dadosIniciais.find(x => x.id === id);
            if (f) editarFornecedor(f);
        }

        function abrirEdicao(i) {
            editarFornecedor(resultadosBusca[i]);
            bootstrap.Modal.getOrCreateInstance(document.getElementById('modalFornecedor')).show();
        }

        // ===== Helpers AJAX dos cadastros rapidos =====
        function alertaErro(m) { return '<div class="alert alert-danger py-1 px-2 small mb-2">' + m + '</div>'; }
        async function postJson(url, body) {
            const token = document.querySelector('#formTokenAjax input[name="__RequestVerificationToken"]').value;
            const resp = await fetch(url, { method: 'POST', headers: { 'Content-Type': 'application/json', 'RequestVerificationToken': token }, body: JSON.stringify(body) });
            return await resp.json();
        }

        async function salvarCidadeRapido() {
            const nome = document.getElementById('cidNome').value.trim();
            const idEstado = document.getElementById('cidEstado').value;
            const msg = document.getElementById('cidMsg');
            const btn = document.getElementById('btnSalvarCidadeRapido');
            msg.innerHTML = '';
            if (!nome) { msg.innerHTML = alertaErro('Informe o nome da cidade.'); return; }
            if (!idEstado) { msg.innerHTML = alertaErro('Selecione o estado.'); return; }
            btn.disabled = true;
            try {
                const data = await postJson('?handler=CidadeRapido', { nmCidade: nome, idEstado: parseInt(idEstado) });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }
                const sel = document.getElementById('formIdCidade');
                const opt = document.createElement('option');
                opt.value = data.id; opt.textContent = data.nome + ' / ' + data.uf;
                sel.appendChild(opt); sel.value = data.id;
                document.getElementById('cidNome').value = '';
                document.getElementById('cidEstado').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalCidadeRapido')).hide();
            } catch (e) { msg.innerHTML = alertaErro('Erro ao salvar a cidade. Tente novamente.'); }
            finally { btn.disabled = false; }
        }

        async function salvarEstadoRapido() {
            const nome = document.getElementById('estNome').value.trim();
            const uf = document.getElementById('estUF').value.trim().toUpperCase();
            const idPais = document.getElementById('estPais').value;
            const msg = document.getElementById('estMsg');
            const btn = document.getElementById('btnSalvarEstadoRapido');
            msg.innerHTML = '';
            if (!nome) { msg.innerHTML = alertaErro('Informe o nome do estado.'); return; }
            if (uf.length !== 2) { msg.innerHTML = alertaErro('Informe a UF (2 letras).'); return; }
            if (!idPais) { msg.innerHTML = alertaErro('Selecione o pais.'); return; }
            btn.disabled = true;
            try {
                const data = await postJson('?handler=EstadoRapido', { sgUF: uf, nmEstado: nome, idPais: parseInt(idPais) });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }
                const sel = document.getElementById('cidEstado');
                const opt = document.createElement('option');
                opt.value = data.id; opt.textContent = data.nome + ' / ' + data.uf;
                sel.appendChild(opt); sel.value = data.id;
                document.getElementById('estNome').value = '';
                document.getElementById('estUF').value = '';
                document.getElementById('estPais').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalEstadoRapido')).hide();
            } catch (e) { msg.innerHTML = alertaErro('Erro ao salvar o estado. Tente novamente.'); }
            finally { btn.disabled = false; }
        }

        async function salvarPaisRapido() {
            const nome = document.getElementById('paisNome').value.trim();
            const sigla = document.getElementById('paisSigla').value.trim().toUpperCase();
            const ddi = document.getElementById('paisDDI').value.trim();
            const moeda = document.getElementById('paisMoeda').value.trim();
            const msg = document.getElementById('paisMsg');
            const btn = document.getElementById('btnSalvarPaisRapido');
            msg.innerHTML = '';
            if (!nome) { msg.innerHTML = alertaErro('Informe o nome do pais.'); return; }
            if (!sigla) { msg.innerHTML = alertaErro('Informe a sigla do pais.'); return; }
            btn.disabled = true;
            try {
                const data = await postJson('?handler=PaisRapido', { nmPais: nome, sgPais: sigla, nrDDI: ddi || null, dsMoeda: moeda || null });
                if (!data.sucesso) { msg.innerHTML = alertaErro(data.mensagem); return; }
                const sel = document.getElementById('estPais');
                const opt = document.createElement('option');
                opt.value = data.id; opt.textContent = data.nome;
                sel.appendChild(opt); sel.value = data.id;
                document.getElementById('paisNome').value = '';
                document.getElementById('paisSigla').value = '';
                document.getElementById('paisDDI').value = '';
                document.getElementById('paisMoeda').value = '';
                bootstrap.Modal.getInstance(document.getElementById('modalPaisRapido')).hide();
            } catch (e) { msg.innerHTML = alertaErro('Erro ao salvar o pais. Tente novamente.'); }
            finally { btn.disabled = false; }
        }

        // ===== Busca de Fornecedores via AJAX =====
        aplicarMascara('buscaDocumento', mascaraCNPJ);
        ['buscaId', 'buscaRazao', 'buscaFantasia', 'buscaDocumento'].forEach(id => {
            document.getElementById(id)?.addEventListener('keydown', e => {
                if (e.key === 'Enter') { e.preventDefault(); buscarFornecedores(); }
            });
        });

        function statusBadge(ativo) {
            return ativo ? '<span class="badge-status badge-ativo">Ativo</span>' : '<span class="badge-status badge-inativo">Inativo</span>';
        }
        function documentoExibicao(f) {
            if (f.tipoPessoa === 'F') return f.cpf ? mascaraCPF(f.cpf) : '-';
            if (f.tipoPessoa === 'E' || f.tipoPessoa === 'O') return f.documento || '-';
            return f.cnpj ? mascaraCNPJ(f.cnpj) : '-';
        }

        function montarLinha(f, i, token) {
            const tel = f.celular || f.telefoneFixo;
            return '<tr>' +
                '<td>' + f.id + '</td>' +
                '<td><strong>' + (f.razaoSocial || '') + '</strong></td>' +
                '<td>' + (f.nomeFantasia || '-') + '</td>' +
                '<td>' + documentoExibicao(f) + '</td>' +
                '<td>' + (tel ? mascaraTelefone(tel) : '-') + '</td>' +
                '<td>' + (f.cidadeNome || '-') + '</td>' +
                '<td>' + statusBadge(f.ativo) + '</td>' +
                '<td class="text-center">' +
                    '<button class="btn btn-icon btn-outline-primary" title="Editar" onclick="abrirEdicao(' + i + ')"><i class="bi bi-pencil"></i></button> ' +
                    '<form method="post" action="?handler=Delete" class="d-inline" onsubmit="return confirm(\'Deseja realmente excluir este fornecedor?\')">' +
                        '<input type="hidden" name="__RequestVerificationToken" value="' + token + '">' +
                        '<input type="hidden" name="id" value="' + f.id + '">' +
                        '<button type="submit" class="btn btn-icon btn-outline-danger" title="Excluir"><i class="bi bi-trash"></i></button>' +
                    '</form>' +
                '</td>' +
            '</tr>';
        }

        async function buscarFornecedores() {
            const tbody = document.querySelector('#tblFornecedores tbody');
            const id = document.getElementById('buscaId').value.trim();
            const razao = document.getElementById('buscaRazao').value.trim();
            const fantasia = document.getElementById('buscaFantasia').value.trim();
            const documento = document.getElementById('buscaDocumento').value.trim();
            const inativos = document.getElementById('buscaInativos').checked;

            const params = new URLSearchParams();
            if (id) params.append('id', id);
            if (razao) params.append('razao', razao);
            if (fantasia) params.append('fantasia', fantasia);
            if (documento) params.append('documento', documento);
            params.append('incluirInativos', inativos);

            tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-3">Buscando...</td></tr>';
            try {
                const resp = await fetch('?handler=BuscarFornecedores&' + params.toString());
                resultadosBusca = await resp.json();

                const contador = document.getElementById('contadorRegistros');
                if (contador) contador.textContent = resultadosBusca.length + ' registros encontrados';

                if (!resultadosBusca.length) {
                    tbody.innerHTML = '<tr><td colspan="8" class="text-center text-muted py-4">Nenhum fornecedor encontrado</td></tr>';
                    return;
                }
                const token = document.querySelector('#formTokenAjax input[name="__RequestVerificationToken"]').value;
                tbody.innerHTML = resultadosBusca.map((f, i) => montarLinha(f, i, token)).join('');
            } catch (e) {
                tbody.innerHTML = '<tr><td colspan="8" class="text-center text-danger py-4">Erro ao buscar. Tente novamente.</td></tr>';
            }
        }
    </script>
}
