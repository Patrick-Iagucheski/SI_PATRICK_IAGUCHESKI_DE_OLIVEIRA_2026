@page
@model WebAppERP.Pages.Cadastro.FornecedoresModel
@{
    ViewData["Title"] = "Fornecedores";

    string FormatarCPF(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        return d.Length == 11 ? $"{d[..3]}.{d.Substring(3, 3)}.{d.Substring(6, 3)}-{d.Substring(9, 2)}" : (v ?? "");
    }
    string FormatarCNPJ(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        return d.Length == 14 ? $"{d[..2]}.{d.Substring(2, 3)}.{d.Substring(5, 3)}/{d.Substring(8, 4)}-{d.Substring(12, 2)}" : (v ?? "");
    }
    string FormatarTelefone(string? v)
    {
        var d = new string((v ?? "").Where(char.IsDigit).ToArray());
        if (d.Length == 11) return $"({d[..2]}) {d.Substring(2, 5)}-{d.Substring(7, 4)}";
        if (d.Length == 10) return $"({d[..2]}) {d.Substring(2, 4)}-{d.Substring(6, 4)}";
        return string.IsNullOrEmpty(v) ? "-" : v;
    }
    string DocExib(WebAppERP.Models.GerFornecedor f) => f.TpPessoa switch
    {
        "F" => FormatarCPF(f.NrCpf),
        "E" or "O" => f.NrDocumento ?? "",
        _ => FormatarCNPJ(f.NrCNPJ)
    };
}

<div class="d-flex justify-content-between align-items-start mb-4">
    <div>
        <h1 class="page-title">Fornecedores</h1>
        <p class="page-subtitle">Gerencie os fornecedores cadastrados no sistema</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#modalFornecedor" onclick="limparForm()">
        <i class="bi bi-plus-lg me-1"></i> Novo Fornecedor
    </button>
</div>

@if (TempData["ErroFornecedor"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-1"></i> @TempData["ErroFornecedor"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Filtros de busca (todos opcionais e combinaveis) -->
<div class="card mb-3">
    <div class="card-body py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-2">
                <label class="form-label small mb-1">ID</label>
                <input type="number" class="form-control" id="buscaId" min="1" autocomplete="off" />
            </div>
            <div class="col-md-4">
                <label class="form-label small mb-1">Razao Social</label>
                <input type="text" class="form-control" id="buscaRazao" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">Nome Fantasia</label>
                <input type="text" class="form-control" id="buscaFantasia" autocomplete="off" />
            </div>
            <div class="col-md-3">
                <label class="form-label small mb-1">CPF / CNPJ</label>
                <input type="text" class="form-control" id="buscaDocumento" autocomplete="off" />
            </div>
        </div>
        <div class="d-flex justify-content-between align-items-center mt-3">
            <div class="form-check mb-0">
                <input class="form-check-input" type="checkbox" id="buscaInativos" onchange="buscarFornecedores()" />
                <label class="form-check-label" for="buscaInativos">Exibir Fornecedores Inativos</label>
            </div>
            <button type="button" class="btn btn-primary" onclick="buscarFornecedores()">
                <i class="bi bi-search me-1"></i>Buscar
            </button>
        </div>
    </div>
</div>

<!-- Tabela -->
<div class="table-container">
    <div class="table-header">
        <h5><i class="bi bi-truck me-2"></i>Lista de Fornecedores</h5>
        <span class="text-muted small" id="contadorRegistros">@Model.Fornecedores.Count registros encontrados</span>
    </div>
    <div class="table-responsive">
        <table class="table" id="tblFornecedores">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Razao Social</th>
                    <th>Nome Fantasia</th>
                    <th>CPF / CNPJ</th>
                    <th>Telefone</th>
                    <th>Cidade</th>
                    <th>Status</th>
                    <th class="text-center">Acoes</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Fornecedores.Any())
                {
                    @foreach (var f in Model.Fornecedores)
                    {
                        <tr>
                            <td>@f.IdFornecedor</td>
                            <td><strong>@f.DsRazaoSocial</strong></td>
                            <td>@(string.IsNullOrWhiteSpace(f.DsNomeFantasia) ? "-" : f.DsNomeFantasia)</td>
                            <td>@(string.IsNullOrEmpty(DocExib(f)) ? "-" : DocExib(f))</td>
                            <td>@FormatarTelefone(f.NrCelular ?? f.NrTelefoneFixo)</td>
                            <td>@(f.Cidade != null ? $"{f.Cidade.NmCidade}/{f.Cidade.Estado?.SgUF}" : "-")</td>
                            <td>
                                @if (f.FlAtivo)
                                {
                                    <span class="badge-status badge-ativo">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge-status badge-inativo">Inativo</span>
                                }
                            </td>
                            <td class="text-center">
                                <button class="btn btn-icon btn-outline-primary" title="Editar"
                                        data-bs-toggle="modal" data-bs-target="#modalFornecedor"
                                        onclick="editarPorId(@f.IdFornecedor)">
                                    <i class="bi bi-pencil"></i>
                                </button>
                                <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('Deseja realmente excluir este fornecedor?')">
                                    <input type="hidden" name="id" value="@f.IdFornecedor" />
                                    <button type="submit" class="btn btn-icon btn-outline-danger" title="Excluir">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="8" class="text-center text-muted py-4">Nenhum fornecedor cadastrado</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Modal Novo/Editar Fornecedor -->
<div class="modal fade" id="modalFornecedor" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <form method="post">
                <div class="modal-header">
                    <h5 class="modal-title" id="modalTitle"><i class="bi bi-truck me-2"></i>Novo Fornecedor</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" asp-for="FornecedorForm.IdFornecedor" id="formId" />

                    <!-- ===== Dados Cadastrais ===== -->
                    <h6 class="text-primary border-bottom pb-1 mb-3"><i class="bi bi-card-list me-1"></i>Dados Cadastrais</h6>
                    <div class="row g-3">
                        <div class="col-md-2">
                            <label class="form-label">Codigo</label>
                            <input type="text" class="form-control bg-light" id="formCodigoDisplay" placeholder="(novo)" readonly />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Tipo de Pessoa *</label>
                            <select class="form-select" asp-for="FornecedorForm.TpPessoa" id="formTpPessoa" onchange="toggleTipoPessoa()">
                                <option value="J">Pessoa Juridica</option>
                                <option value="F">Pessoa Fisica</option>
                                <option value="E">Estrangeiro</option>
                                <option value="O">Outro</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" id="lblRazao">Razao Social *</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsRazaoSocial" id="formDsRazaoSocial" maxlength="200" required />
                        </div>

                        <div class="col-md-6">
                            <label class="form-label">Nome Fantasia</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsNomeFantasia" id="formDsNomeFantasia" maxlength="150" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Contato Principal</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsContatoPrincipal" id="formDsContatoPrincipal" maxlength="120" />
                        </div>

                        <div class="col-md-3 doc-wrap" id="wrapCnpj">
                            <label class="form-label">CNPJ</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrCNPJ" id="formNrCNPJ" maxlength="18" placeholder="00.000.000/0000-00" />
                        </div>
                        <div class="col-md-3 doc-wrap d-none" id="wrapCpf">
                            <label class="form-label">CPF</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrCpf" id="formNrCpf" maxlength="14" placeholder="000.000.000-00" />
                        </div>
                        <div class="col-md-3 doc-wrap d-none" id="wrapDoc">
                            <label class="form-label" id="lblDoc">Documento</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrDocumento" id="formNrDocumento" maxlength="30" placeholder="Documento" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Inscricao Estadual</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrInscEstadual" id="formNrInscEstadual" maxlength="20" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Inscricao Municipal</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrInscMunicipal" id="formNrInscMunicipal" maxlength="20" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Status</label>
                            <select class="form-select" asp-for="FornecedorForm.FlAtivo" id="formFlAtivo">
                                <option value="true">Ativo</option>
                                <option value="false">Inativo</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label">Observacoes</label>
                            <textarea class="form-control" rows="2" asp-for="FornecedorForm.DsObservacao" id="formDsObservacao" maxlength="500"></textarea>
                        </div>
                    </div>

                    <!-- ===== Endereco ===== -->
                    <h6 class="text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-geo-alt me-1"></i>Endereco</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">CEP</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrCEP" id="formNrCEP" maxlength="9" placeholder="00000-000" />
                        </div>
                        <div class="col-md-7">
                            <label class="form-label">Logradouro</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsEndereco" id="formDsEndereco" maxlength="200" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Numero</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrNumero" id="formNrNumero" maxlength="10" />
                        </div>
                        <div class="col-md-5">
                            <label class="form-label">Complemento</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsComplemento" id="formDsComplemento" maxlength="100" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Bairro</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsBairro" id="formDsBairro" maxlength="100" />
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Cidade</label>
                            <div class="input-group">
                                <select class="form-select" asp-for="FornecedorForm.IdCidade" id="formIdCidade">
                                    <option value="">Selecione</option>
                                    @foreach (var cidade in Model.Cidades)
                                    {
                                        <option value="@cidade.IdCidade">@cidade.NmCidade / @cidade.Estado?.SgUF</option>
                                    }
                                </select>
                                <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal"
                                        data-bs-target="#modalCidadeRapido" title="Cadastrar nova cidade">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- ===== Contato ===== -->
                    <h6 class="text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-telephone me-1"></i>Contato</h6>
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label">Telefone Fixo</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrTelefoneFixo" id="formNrTelefoneFixo" maxlength="15" placeholder="(00) 0000-0000" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Celular</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrCelular" id="formNrCelular" maxlength="15" placeholder="(00) 00000-0000" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">WhatsApp</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrWhatsApp" id="formNrWhatsApp" maxlength="15" placeholder="(00) 00000-0000" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">E-mail Principal</label>
                            <input type="email" class="form-control" asp-for="FornecedorForm.DsEmail" id="formDsEmail" maxlength="150" />
                        </div>
                    </div>

                    <!-- ===== Dados Bancarios ===== -->
                    <h6 class="text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-bank me-1"></i>Dados Bancarios</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Banco</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsBanco" id="formDsBanco" maxlength="60" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Agencia</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrAgencia" id="formNrAgencia" maxlength="10" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Tipo de Conta</label>
                            <select class="form-select" asp-for="FornecedorForm.TpConta" id="formTpConta">
                                <option value="">Selecione</option>
                                <option value="CC">Conta Corrente</option>
                                <option value="CP">Conta Poupanca</option>
                                <option value="CS">Conta Salario</option>
                                <option value="CE">Conta Empresarial</option>
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">Conta</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrConta" id="formNrConta" maxlength="20" />
                        </div>
                        <div class="col-md-1">
                            <label class="form-label">Digito</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.NrDigitoConta" id="formNrDigitoConta" maxlength="2" />
                        </div>
                    </div>

                    <!-- ===== PIX ===== -->
                    <h6 class="text-primary border-bottom pb-1 mb-3 mt-4"><i class="bi bi-qr-code me-1"></i>PIX</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label">Tipo de Chave PIX</label>
                            <select class="form-select" asp-for="FornecedorForm.TpChavePix" id="formTpChavePix" onchange="aplicarMascaraPix()">
                                <option value="">Selecione</option>
                                <option value="CPF">CPF</option>
                                <option value="CNPJ">CNPJ</option>
                                <option value="EMAIL">E-mail</option>
                                <option value="CELULAR">Celular</option>
                                <option value="ALEATORIA">Chave Aleatoria</option>
                            </select>
                        </div>
                        <div class="col-md-8">
                            <label class="form-label">Chave PIX</label>
                            <input type="text" class="form-control" asp-for="FornecedorForm.DsChavePix" id="formDsChavePix" maxlength="100" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg me-1"></i>Salvar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Modal de Cadastro Rapido de Cidade (AJAX) -->
<div class="modal fade" id="modalCidadeRapido" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-building me-2"></i>Cadastrar Cidade</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="cidMsg"></div>
                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Nome da Cidade *</label>
                        <input type="text" class="form-control" id="cidNome" maxlength="150" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Estado *</label>
                        <div class="input-group">
                            <select class="form-select" id="cidEstado">
                                <option value="">Selecione</option>
                                @foreach (var estado in Model.Estados)
                                {
                                    <option value="@estado.IdEstado">@estado.NmEstado / @estado.SgUF</option>
                                }
                            </select>
                            <button type="button" class="btn btn-outline-primary" data-bs-toggle="modal"
                                    data-bs-target="#modalEstadoRapido" title="Cadastrar novo estado">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="btnSalvarCidadeRapido" onclick="salvarCidadeRapido()">
                    <i class="bi bi-check-lg me-1"></i>Salvar Cidade
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Cadastro Rapido de Estado (AJAX) -->
