<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SoftwareERP</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebAppERP.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar">
            <div class="sidebar-header">
                <i class="bi bi-scissors"></i>
                <span class="sidebar-brand">SoftwareERP</span>
            </div>
            <ul class="sidebar-nav">
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Index" ? "active" : "")" asp-page="/Index">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Dashboard</span>
                    </a>
                </li>
                <li class="sidebar-divider"></li>
                <li class="sidebar-heading">Cadastros</li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Clientes" ? "active" : "")" asp-page="/Cadastro/Clientes">
                        <i class="bi bi-people-fill"></i>
                        <span>Clientes</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Funcionarios" ? "active" : "")" asp-page="/Cadastro/Funcionarios">
                        <i class="bi bi-person-badge-fill"></i>
                        <span>Funcionarios</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Servicos" ? "active" : "")" asp-page="/Cadastro/Servicos">
                        <i class="bi bi-card-checklist"></i>
                        <span>Servicos</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Fornecedores" ? "active" : "")" asp-page="/Cadastro/Fornecedores">
                        <i class="bi bi-truck"></i>
                        <span>Fornecedores</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Transportadores" ? "active" : "")" asp-page="/Cadastro/Transportadores">
                        <i class="bi bi-truck-front"></i>
                        <span>Transportadores</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Veiculos" ? "active" : "")" asp-page="/Cadastro/Veiculos">
                        <i class="bi bi-truck-flatbed"></i>
                        <span>Veiculos</span>
                    </a>
                </li>
                <li class="sidebar-divider"></li>
                <li class="sidebar-heading">Localidades</li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Paises" ? "active" : "")" asp-page="/Cadastro/Paises">
                        <i class="bi bi-globe-americas"></i>
                        <span>Paises</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Estados" ? "active" : "")" asp-page="/Cadastro/Estados">
                        <i class="bi bi-map"></i>
                        <span>Estados</span>
                    </a>
                </li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Cidades" ? "active" : "")" asp-page="/Cadastro/Cidades">
                        <i class="bi bi-building"></i>
                        <span>Cidades</span>
                    </a>
                </li>
                <li class="sidebar-divider"></li>
                <li class="sidebar-heading">Operacional</li>
                <li class="sidebar-item">
                    <a class="sidebar-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Cadastro/Agendamentos" ? "active" : "")" asp-page="/Cadastro/Agendamentos">
                        <i class="bi bi-calendar-check-fill"></i>
                        <span>Agendamentos</span>
                    </a>
                </li>
            </ul>
            <div class="sidebar-footer">
                <i class="bi bi-person-circle"></i>
                <span>Admin</span>
            </div>
        </nav>

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100">
            <nav class="navbar navbar-expand-lg navbar-light topbar">
                <div class="container-fluid">
                    <button class="btn btn-link" id="sidebarToggle">
                        <i class="bi bi-list fs-4"></i>
                    </button>
                    <span class="navbar-text fw-semibold text-muted">
                        @ViewData["Title"]
                    </span>
                    <div class="d-flex align-items-center gap-3">
                        <span class="text-muted small">@DateTime.Now.ToString("dd/MM/yyyy")</span>
                        <div class="topbar-divider"></div>
                        <div class="dropdown">
                            <a class="btn btn-link text-dark text-decoration-none dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i> Admin
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Configuracoes</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" href="#"><i class="bi bi-box-arrow-right me-2"></i>Sair</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </nav>
            <div class="container-fluid p-4">
                <main role="main">
                    @RenderBody()
                </main>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script>
        document.getElementById('sidebarToggle')?.addEventListener('click', function () {
            document.getElementById('wrapper').classList.toggle('sidebar-collapsed');
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
